#!/usr/bin/env bash
#
# virtdev-seal
#
# Promotes installed base system images to sealed, read-only
# backing files from which per-project delta images are derived.
#
# Reads from  ${VIRTDEV_HOME}/installation/
# Writes to   ${VIRTDEV_HOME}/system/
#
# On success, the installation directory is removed.
#
# Run virtdev-install <iso> first to produce the installation directory.
# Run virtdev-create <project> after sealing to create a project VM.
#

set -euo pipefail

# shellcheck disable=SC1090,SC1091
source "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev/import"

import error lock arguments terminal

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"

# shellcheck disable=SC2034  # spec read via nameref
declare -A spec=()
# shellcheck disable=SC2034
declare -A flags=()
declare -a positional=()
arguments_parse spec flags positional "$@"
set -- "${positional[@]}"

if [[ $# -ne 0 ]]; then
  error 64 <<<"$(arguments_usage spec)"
fi

lock_acquire

installation_directory="${VIRTDEV_HOME}/installation"
system_directory="${VIRTDEV_HOME}/system"

if [[ ! -d "${installation_directory}" ]]; then
  error 3 <<<"Installation directory not found: '${installation_directory}'"
fi

if [[ -d "${system_directory}" ]]; then
  error 4 <<MESSAGE
Sealed base system images already present: '${system_directory}'
Remove the system directory manually to reseal.
MESSAGE
fi

system_disk="${installation_directory}/system.qcow2"
home_disk="${installation_directory}/home.qcow2"
nvram="${installation_directory}/nvram"

for f in "${system_disk}" "${home_disk}" "${nvram}"; do
  if [[ ! -f "${f}" ]]; then
    error 5 <<<"Installation file not found: '${f}'"
  fi
done

printf >&2 'Checking image integrity...\n'
if ! qemu-img check -q "${system_disk}"; then
  error 6 <<<"System disk image integrity check failed: '${system_disk}'"
fi
if ! qemu-img check -q "${home_disk}"; then
  error 7 <<<"Home disk image integrity check failed: '${home_disk}'"
fi

mkdir -p "${system_directory}"

printf >&2 "Sealing base system images to '%s'...\n" "${system_directory}"
mv "${system_disk}" "${system_directory}"/
mv "${home_disk}"   "${system_directory}"/
mv "${nvram}"       "${system_directory}"/

printf >&2 'Writing generation counter...\n'
printf '1\n' > "${system_directory}/generation"

printf >&2 'Marking base system images read-only...\n'
chmod 444 "${system_directory}"/*

printf >&2 'Removing installation directory...\n'
if ! rmdir "${installation_directory}" 2>/dev/null; then
  # rmdir refused: something is in the directory beyond the three
  # files we just moved out. Surface what is left so the user can
  # decide what to do; leave system/ as the successfully sealed
  # base. Don't rm -rf — the leftover state may be the user's work.
  remaining="$(find "${installation_directory}" -mindepth 1 -printf '  %P\n' 2>/dev/null)"
  error 8 <<MESSAGE
Installation directory not empty after sealing: '${installation_directory}'
${remaining}
The base system is sealed at '${system_directory}'.
Inspect the leftover files and remove the directory manually:
    rm -rf '${installation_directory}'
MESSAGE
fi

printf >&2 '%s\n' "$(terminal_write fg=green "Base system sealed: '${system_directory}'" reset)"
printf >&2 'Run virtdev-create <name> to derive a virtual machine.\n'