#!/usr/bin/env bash
#
# virtdev-stop <project>
#
# Shuts down a project virtual machine cleanly via ACPI powerdown.
# Falls back to systemctl stop (SIGTERM) if the monitor is unavailable
# or the guest does not respond within a timeout.
#
# The QEMU monitor socket is used to send 'system_powerdown',
# which triggers a clean ACPI shutdown in the guest.
# It should halt gracefully since systemd sees it as a power button press.
#
# Requires socat.
#
#     pacman -S socat
#

set -euo pipefail

# shellcheck disable=SC1090,SC1091
source "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev/import"

import error validate lock arguments terminal

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"
: "${VIRTDEV_STOP_TIMEOUT:=60}"

# shellcheck disable=SC2034  # spec/companions read via nameref
declare -A spec=()
# shellcheck disable=SC2034
declare -a spec_positionals=(project)
# shellcheck disable=SC2034
declare -A flags=()
declare -a positional=()
arguments_parse spec flags positional "$@"
set -- "${positional[@]}"

if [[ $# -ne 1 ]]; then
  error 64 <<<"$(arguments_usage spec)"
fi

project="${1}"

validate_project_name "${project}"

# The maintenance virtual machine is the one target that skips the
# virtdev lock. virtdev-maintain holds the exclusive lock for its
# entire session, so requiring it here would make 'virtdev-stop
# maintenance' — the documented abort path — fail with lock
# contention exactly when it is needed. Skipping is safe: maintain
# has already serialized everything else, and the only virtdev
# virtual machine that can be running during a maintain session is
# virtdev-maintenance itself. Concurrent cleanup between this
# script and maintain's post-exit path is idempotent (rm -f on
# missing paths, rmdir || true) by construction. Unit state
# (reset-failed) is owned strictly by maintain; see the conditional
# guarding the reset-failed call below.
if [[ "${project}" != "maintenance" ]]; then
  lock_acquire
fi

unit=virtdev-"${project}"
project_directory="${VIRTDEV_HOME}"/projects/"${project}"
monitor_sock="${project_directory}"/monitor.sock

if [[ ! -d "${project_directory}" ]]; then
  error 3 <<<"Project not found: ${project}"
fi

if ! systemctl --user --quiet is-active "${unit}" 2>/dev/null; then
  error 4 <<<"Project virtual machine is not running: ${project}"
fi

if ! command -v socat &>/dev/null; then
  printf '%s\n' "$(terminal_write fg=yellow 'socat not found, falling back to SIGTERM...' reset)"
  systemctl --user stop "${unit}"
  rm -f "${project_directory}"/port \
       "${project_directory}"/monitor.sock \
       "${project_directory}"/console.sock
  printf '%s\n' "$(terminal_write fg=green "Project virtual machine stopped: ${project}" reset)"
  exit 0
fi

# Dispatch the stop. Three branches: ACPI (preferred), SIGTERM with
# socket present but ACPI send failed, SIGTERM with no monitor
# socket. The ACPI success path falls through with no body — the
# unified wait loop below handles all three.
if [[ -S "${monitor_sock}" ]]; then
  printf "Sending ACPI powerdown to: %s\n" "${project}"
  # Unidirectional socat: close after stdin EOF instead of waiting for the
  # server to close the socket. QEMU only closes the monitor when the VM
  # process itself exits, so bidirectional 'socat -' would block here
  # indefinitely if the guest ignored the ACPI event (wedged kernel,
  # masked poweroff target, etc). Decoupling send from wait lets the
  # ActiveState poll below enforce VIRTDEV_STOP_TIMEOUT as the actual
  # upper bound on the stop.
  if ! echo 'system_powerdown' | socat -u - UNIX-CONNECT:"${monitor_sock}" &>/dev/null; then
    printf '%s\n' "$(terminal_write fg=yellow 'Monitor send failed, falling back to SIGTERM...' reset)"
    systemctl --user stop "${unit}"
  fi
else
  printf '%s\n' "$(terminal_write fg=yellow 'Monitor socket not found, falling back to SIGTERM...' reset)"
  systemctl --user stop "${unit}"
fi

# Wait for the unit to settle into a terminal state (inactive or
# failed). After ACPI we wait for the guest to halt; after SIGTERM
# we wait for QEMU to exit and the user manager to update the unit's
# ActiveState. 'systemctl --user stop' returns once the stop job is
# queued, not after the transition completes, and the user manager's
# queue can be congested — so the SIGTERM-fallback paths above MUST
# settle here before the post-condition assertion runs. Without this
# wait, the post-condition would fire on an in-flight 'deactivating'
# state and produce a spurious error 5 for an otherwise-successful
# stop.
#
# If the deadline expires while the unit is still active or
# activating, escalate ACPI to SIGTERM once and resume waiting; if
# SIGTERM also fails to land in time, exit the loop and let the
# post-condition surface the stuck state.
deadline=$(( SECONDS + VIRTDEV_STOP_TIMEOUT ))
escalated=0
while :; do
  active_state="$(systemctl --user show "${unit}" --property=ActiveState --value 2>/dev/null || true)"
  case "${active_state}" in
    inactive|failed) break ;;
  esac
  if (( SECONDS >= deadline )); then
    if (( ! escalated )); then
      printf '%s\n' "$(terminal_write fg=yellow "Guest did not halt within ${VIRTDEV_STOP_TIMEOUT}s, falling back to SIGTERM..." reset)"
      systemctl --user stop "${unit}"
      escalated=1
      deadline=$(( SECONDS + VIRTDEV_STOP_TIMEOUT ))
      continue
    fi
    break
  fi
  sleep 1
done

# Post-condition: the loop above must leave the unit in a terminal
# state (inactive or failed). This catches bugs where a future change
# adds a fallthrough that skips a wait, and serves as a hard floor on
# the contract that virtdev-stop only returns when QEMU is gone.
case "${active_state}" in
  inactive|failed) ;;
  *)
    error 5 <<MESSAGE
Unit ${unit} is in unexpected state after stop: '${active_state}'.
Expected 'inactive' or 'failed'. The VM may still be running.
Investigate: systemctl --user status ${unit}
MESSAGE
    ;;
esac

# Capture the raw QEMU exit status for the user. Typical values:
#   0       clean guest poweroff
#   143     SIGTERM (our SIGTERM fallback path or external 'systemctl stop')
#   128+N   killed by signal N
#   other   QEMU-level error
qemu_exit="$(systemctl --user show "${unit}" --property=ExecMainStatus --value 2>/dev/null || true)"
qemu_exit="${qemu_exit:-?}"

# Reset any residual failed state so the next virtdev-start does not
# hit a name collision. Done after the ExecMainStatus capture, which
# needs the unit to still be loaded.
#
# Skipped when target is 'maintenance': virtdev-maintain owns the
# unit lifecycle there. It calls reset-failed before its systemd-run
# and again at end-of-session (clean and error paths). Doing it
# here would race with maintain's read of ExecMainStatus in the
# narrow window between maintain's wait-loop seeing 'inactive' and
# its show --property capture: clearing the property leaves maintain
# reading empty, which it coerces to 'unknown' and treats as
# abnormal exit, refusing the reseal of an otherwise-clean session.
# The cosmetic cost (the unit lingers in 'failed' between sessions
# when virtdev-stop maintenance is used) is paid by the next
# virtdev-maintain run via its pre-systemd-run reset-failed.
if [[ "${project}" != "maintenance" ]]; then
  systemctl --user reset-failed "${unit}" 2>/dev/null || true
fi

rm -f "${project_directory}"/port \
     "${project_directory}"/monitor.sock \
     "${project_directory}"/console.sock
printf '%s\n' "$(terminal_write fg=green "Project virtual machine stopped: ${project}" reset " (QEMU exit ${qemu_exit})")"