#!/usr/bin/env bash
#
# virtdev-maintain
#
# Boots the sealed base system in a writable maintenance staging area
# where it is possible to configure and update the system
# as well as seed dotfiles into the base system home disk.
# Reseals automatically on clean power off
# as signaled by the systemd unit exit status
# after explicit confirmation from the user.
#
# Workflow:
#
#   1. Copy system/ to maintenance/
#   2. Make maintenance/ images writable
#   3. Start the maintenance virtual machine as a systemd user service on port 2222
#   4. Connect via SSH once the virtual machine is ready: virtdev-ssh maintenance
#   5. Perform maintenance inside the virtual machine
#      5.1. Update system
#      5.2. Configure system
#      5.3. Seed dotfiles
#   6. Power off, not reboot: sudo poweroff
#   7. On clean exit
#      7.1. Integrity check
#      7.2. Confirm reseal
#           7.2.1 Replace system/ with maintenance/
#
# If the virtual machine does not exit cleanly,
# as signaled by a non-zero systemd unit exit status
# QEMU failure or SIGINT from Ctrl-C or virtdev-stop,
# maintenance/ is left intact for inspection
# and the sealed system/ is unchanged.
# Remove maintenance/ manually to retry.
#
# The maintenance virtual machine runs as a systemd user service
# named virtdev-maintenance. Use standard systemd and virtdev tools
# to inspect or stop it:
#
#   virtdev-ssh maintenance
#   virtdev-stop maintenance
#   systemctl --user status virtdev-maintenance
#   journalctl --user -u virtdev-maintenance
#
# All running project virtual machines
# must be stopped before running virtdev-maintain.
# Project virtual machines use system/system.qcow2
# as a backing file. Replacing it under a running
# virtual machine would corrupt its delta image.
#
# After resealing:
#
#   - Project virtual machines in delta mode
#     do not pick up changes automatically.
#     Recreate them with virtdev-destroy + virtdev-create.
#   - Project virtual machines in shared read-only mode
#     pick up changes to the system disk on next boot.
#
# Configuration via environment variables:
#
#   VIRTDEV_HOME              Default: ${XDG_DATA_HOME:-~/.local/share}/virtdev
#   VIRTDEV_SSH_KEY           Default: ${VIRTDEV_HOME}/ssh/id
#   VIRTDEV_WAIT_TIMEOUT      Seconds to wait for SSH. Default: 120
#   VIRTDEV_STOP_TIMEOUT      Seconds to wait for the maintenance unit
#                             to leave active state after stop. Default: 60
#   VIRTDEV_VM_MEMORY         Default: 4096
#   VIRTDEV_VM_CPUS           Default: 4
#   OVMF_CODE                 Default: /usr/share/edk2/x64/OVMF_CODE.4m.fd
#

set -euo pipefail

virtdev_library_directory="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev"
declare -A virtdev_loaded_libraries=()
import() {
  local f
  for f in "$@"; do
    [[ -v virtdev_loaded_libraries[$f] ]] && continue
    virtdev_loaded_libraries[$f]=1
    # shellcheck disable=SC1090
    source -p "${virtdev_library_directory}" "${f}"
  done
}

import error lock arguments

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"
: "${VIRTDEV_SSH_KEY:="${VIRTDEV_HOME}/ssh/id"}"
: "${VIRTDEV_WAIT_TIMEOUT:=120}"
: "${VIRTDEV_STOP_TIMEOUT:=60}"
: "${VIRTDEV_VM_MEMORY:=4096}"
: "${VIRTDEV_VM_CPUS:=4}"
: "${OVMF_CODE:="/usr/share/edk2/x64/OVMF_CODE.4m.fd"}"

readonly maintenance_port=2222
readonly unit=virtdev-maintenance

# shellcheck disable=SC2034  # spec read via nameref
declare -A spec=()
case "${1:-}" in
  --help|-h) arguments_usage spec ; exit 0 ;;
esac
# shellcheck disable=SC2034
declare -A flags=()
declare -a positional=()
arguments_parse spec flags positional "$@"
set -- "${positional[@]}"

if [[ $# -ne 0 ]]; then
  error 64 <<<"$(arguments_usage spec)"
fi

# Held for the entire maintenance session, which may last hours while
# the user runs pacman -Syu or other long operations inside the guest.
lock_acquire_for_maintain

system_directory="${VIRTDEV_HOME}/system"
maintenance_directory="${VIRTDEV_HOME}/maintenance"
maintenance_project="${VIRTDEV_HOME}/projects/maintenance"
old_system_directory="${VIRTDEV_HOME}/system.old"
trash_directory="${VIRTDEV_HOME}/system.old.trash"

# Auto-recover from an interrupted reseal. The reseal block below
# is a two-mv-plus-writes sequence that this commit further wraps
# in a signal trap, but a SIGKILL or host power loss can still
# land in the middle of it and leave the layout in one of these
# partial states:
#
#   - system.old/ exists, system/ does not         (between mv's)
#   - system.old/ exists, system/ has no version   (post-mv, pre-write)
#   - system.old/ and system/ both fully populated (pre-rm-of-old)
#
# In all three, the prior sealed base is intact at system.old/
# and the right move is to unconditionally restore it — clobbering
# whatever partial state is in system/ — so the next operation
# starts from a known-good layout. The in-progress maintenance
# work is discarded; a user who wants to recover it must do so
# from maintenance/ by hand before retrying, but maintenance/ is
# left untouched here so that option stays open.
if [[ -d "${old_system_directory}" ]]; then
  printf 'Detected interrupted reseal from a prior virtdev-maintain.\n'
  if [[ -d "${system_directory}" ]]; then
    printf 'Clobbering partial new base: %s\n' "${system_directory}"
    rm -rf "${system_directory}"
  fi
  printf 'Restoring previous sealed base from: %s\n' "${old_system_directory}"
  mv "${old_system_directory}" "${system_directory}"
  printf 'Recovery complete. Proceed with virtdev-maintain as normal.\n\n'
fi

# Clean up leftover trash from a prior successful reseal whose
# best-effort rm did not finish. trash_directory is created by the
# atomic-rename commit step in the reseal block below; its presence
# means the new base is already committed and the old base is
# garbage. This is distinct from the system.old/ revert case above:
# system.old/ means "reseal interrupted mid-section, revert", while
# trash_directory means "reseal succeeded, just remove the leftover".
if [[ -d "${trash_directory}" ]]; then
  printf 'Removing leftover trash from a prior reseal: %s\n' "${trash_directory}"
  rm -rf "${trash_directory}"
fi

if [[ ! -d "${system_directory}" ]]; then
  error 3 <<MESSAGE
Sealed base system not found: '${system_directory}'
Create it with virtdev-iso, virtdev-install and virtdev-seal.
MESSAGE
fi

for file in system.qcow2 home.qcow2 nvram; do
  if [[ ! -f "${system_directory}/${file}" ]]; then
    error 4 <<<"Base system image missing: '${system_directory}/${file}'"
  fi
done

if [[ -d "${maintenance_directory}" ]]; then
  error 5 <<MESSAGE
Maintenance staging directory already exists: '${maintenance_directory}'
A previous virtdev-maintain session may have failed or been interrupted.
Inspect the directory and remove it manually to proceed:

    rm -rf '${maintenance_directory}'

The original sealed base system should be intact: '${system_directory}'
MESSAGE
fi

if [[ ! -f "${OVMF_CODE}" ]]; then
  error 6 <<<"Firmware not found: '${OVMF_CODE}'"
fi

if [[ ! -f "${VIRTDEV_SSH_KEY}" ]]; then
  error 7 <<MESSAGE
SSH key not found: '${VIRTDEV_SSH_KEY}'
Generate it with virtdev-key then recreate and reinstall base system image.
MESSAGE
fi

# Check for an orphaned virtdev-maintenance unit from a previous
# session before the generic "any virtdev-*.service active" check
# below. Both checks would fire here — virtdev-maintenance matches
# the 'virtdev-*.service' glob — but the generic message tells the
# user to stop their project VMs, which is not what is wrong when
# the only active unit is the maintenance unit itself. A user who
# already cleaned up maintenance/ in response to the "Maintenance
# staging directory already exists" check should not then be told
# to stop nonexistent project VMs.
if systemctl --user --quiet is-active virtdev-maintenance 2>/dev/null; then
  error 8 <<MESSAGE
Orphaned maintenance virtual machine is running (virtdev-maintenance).
A previous virtdev-maintain session was likely interrupted before it
could stop the virtual machine. Terminate it, then retry:

    systemctl --user stop virtdev-maintenance

MESSAGE
fi

# Refuse to run if any project virtual machines are currently running.
# They depend on system/system.qcow2 as a backing file.
# Replacing it while a project virtual machine is running would corrupt it.
if systemctl --user list-units --state=active --no-legend 'virtdev-*.service' \
       2>/dev/null | grep -q .; then
  error 8 <<MESSAGE
One or more project virtual machines are running.
Stop all project virtual machines before running virtdev-maintain:

    virtdev-stop <project>

MESSAGE
fi

if [[ -n "$(ss -tlnH "sport = :${maintenance_port}" 2>/dev/null)" ]]; then
  error 9 <<<"Port ${maintenance_port} is already in use on this host"
fi

mkdir -p "${maintenance_directory}"

system_disk="${maintenance_directory}/system.qcow2"
home_disk="${maintenance_directory}/home.qcow2"
nvram="${maintenance_directory}/nvram"

printf "Copying sealed base images to: '%s'\n" "${maintenance_directory}"
# --reflink=auto produces an instant COW clone on filesystems that
# support reflinks (btrfs, XFS with reflink=1) and silently falls
# back to a full byte copy everywhere else, so the flag is safe to
# pass unconditionally. On supported hosts this replaces a
# (system + home) ~ 72 GiB copy with a near-instantaneous metadata
# operation; the sealed originals stay untouched because subsequent
# writes to the clone get copy-on-write'd.
cp --reflink=auto "${system_directory}/system.qcow2" "${system_disk}"
cp --reflink=auto "${system_directory}/home.qcow2"   "${home_disk}"
cp --reflink=auto "${system_directory}/nvram"        "${nvram}"

printf 'Making maintenance images writable...\n'
chmod 644 "${system_disk}" "${home_disk}" "${nvram}"

# Register maintenance as a virtual project so virtdev-ssh and virtdev-stop work.
mkdir -p "${maintenance_project}"
printf '%d\n' "${maintenance_port}" > "${maintenance_project}/port"

monitor_sock="${maintenance_project}/monitor.sock"
console_sock="${maintenance_project}/console.sock"
rm -f "${monitor_sock}" "${console_sock}"

# Clear residual failed state from a prior session. Mirrors the same
# guard in virtdev-start: without --collect (which we also omit so
# the post-exit ExecMainStatus query below stays queryable), a unit
# that exited with error persists as 'failed' in systemd's state
# until explicitly reset. A SIGKILL of a previous virtdev-maintain
# between its unit's failure and its own cleanup path can leave that
# residue; the systemd-run below would then refuse with
# name-already-in-use.
systemctl --user reset-failed "${unit}" 2>/dev/null || true

printf 'Starting maintenance VM (virtdev-maintenance)...\n'

systemd-run \
    --user \
    --unit="${unit}" \
    --description='virtdev base system maintenance virtual machine' \
    -- \
    qemu-system-x86_64 \
        -enable-kvm \
        -cpu host \
        -machine q35 \
        -m "${VIRTDEV_VM_MEMORY}" \
        -smp "${VIRTDEV_VM_CPUS}" \
        -drive if=pflash,format=raw,readonly=on,file="${OVMF_CODE}" \
        -drive if=pflash,format=raw,file="${nvram}" \
        -drive file="${system_disk}",if=virtio,format=qcow2 \
        -drive file="${home_disk}",if=virtio,format=qcow2 \
        -netdev user,id=net0,hostfwd=tcp:127.0.0.1:"${maintenance_port}"-:22 \
        -device virtio-net-pci,netdev=net0 \
        -device virtio-rng-pci \
        -display none \
        -chardev socket,id=monitor,path="${monitor_sock}",server=on,wait=off \
        -monitor chardev:monitor \
        -chardev socket,id=serial,path="${console_sock}",server=on,wait=off \
        -serial chardev:serial

# Poll until SSH is up or the unit exits early.
printf 'Waiting for SSH on port %d with timeout %ds...' \
       "${maintenance_port}" "${VIRTDEV_WAIT_TIMEOUT}"

ssh_up=0
deadline=$(( SECONDS + VIRTDEV_WAIT_TIMEOUT ))

while (( SECONDS < deadline )); do
  unit_state="$(systemctl --user is-active "${unit}" 2>/dev/null || true)"
  case "${unit_state}" in
    active|activating) ;;
    *) break ;;   # Unit exited before SSH came up
  esac
  if ssh \
      -i "${VIRTDEV_SSH_KEY}" \
      -p "${maintenance_port}" \
      -o BatchMode=yes \
      -o ConnectTimeout=3 \
      -o StrictHostKeyChecking=no \
      -o UserKnownHostsFile=/dev/null \
      -o LogLevel=ERROR \
      dev@127.0.0.1 \
      true 2>/dev/null
  then
    ssh_up=1
    break
  fi
  printf '.'
  sleep 2
done

if [[ "${ssh_up}" -eq 0 ]]; then
  printf ' failed.\n'

  systemctl --user stop "${unit}" 2>/dev/null || true

  # Wait for the unit to actually leave active state before tearing
  # down its sockets and project directory. Without this wait, QEMU
  # may still hold the maintenance disk images and the deleted
  # socket inodes open while the host has already removed the path
  # entries — a subsequent manual 'rm -rf maintenance/' would not
  # free the blocks until QEMU exits, and 'virtdev-list' shows an
  # inconsistent view in the interim. Best-effort: if the unit does
  # not stop within VIRTDEV_STOP_TIMEOUT, proceed with cleanup
  # anyway. The next virtdev-maintain pre-flight will refuse to
  # start because an active unit exists, surfacing the stuck state.
  stop_deadline=$(( SECONDS + VIRTDEV_STOP_TIMEOUT ))
  while systemctl --user --quiet is-active "${unit}" 2>/dev/null; do
    if (( SECONDS >= stop_deadline )); then
      printf >&2 'warning: %s did not stop within %ds; cleanup may leak open file descriptors\n' \
                 "${unit}" "${VIRTDEV_STOP_TIMEOUT}"
      break
    fi
    sleep 1
  done

  systemctl --user reset-failed "${unit}" 2>/dev/null || true
  rm -f "${maintenance_project}/port" "${monitor_sock}" "${console_sock}"
  rmdir "${maintenance_project}" 2>/dev/null || true
  error 10 <<MESSAGE
SSH did not become available within ${VIRTDEV_WAIT_TIMEOUT}s.
The sealed base images are intact: '${system_directory}'
Maintenance images preserved for inspection: '${maintenance_directory}'
Remove manually to retry: rm -rf '${maintenance_directory}'
MESSAGE
fi

printf ' up.\n\n'
printf 'Connect to the maintenance virtual machine:\n\n'
printf '\tvirtdev-ssh maintenance\n\n'
printf 'When done, power off to trigger resealing:\n\n'
printf '\tsudo poweroff\n\n'
printf 'Waiting for virtual machine to exit...\n'
printf 'To abort:\n\n'
printf '\tvirtdev-stop maintenance\n\n'

# Wait for the unit to leave active/activating state.
while true; do
  unit_state="$(systemctl --user is-active "${unit}" 2>/dev/null || true)"
  case "${unit_state}" in
    active|activating) sleep 2 ;;
    *) break ;;
  esac
done

# Capture exit status before reset-failed removes it.
#
# systemctl show returns empty — not non-zero — when the property is
# unset, for instance because something else already reset-failed the
# unit in the narrow window between our wait loop observing the exit
# and this capture. The || echo 1 fallback only triggers on non-zero
# exit and does not catch that path. Fall back to a sentinel on empty
# and compare as a string below: the arithmetic '-ne 0' test coerces
# empty to 0 and would misclassify that path as a clean shutdown.
qemu_exit="$(systemctl --user show "${unit}" \
    --property=ExecMainStatus --value 2>/dev/null || echo 1)"
qemu_exit="${qemu_exit:-unknown}"

systemctl --user reset-failed "${unit}" 2>/dev/null || true
rm -f "${maintenance_project}/port" "${monitor_sock}" "${console_sock}"
rmdir "${maintenance_project}" 2>/dev/null || true

printf '\n'

# Any non-zero exit means the maintenance session did not finish
# with a clean guest poweroff. The sealed base must NOT be
# overwritten in that case: ext4 journal replay needs write
# access, half-applied pacman transactions produce inconsistent
# package state, and so on. Preserve maintenance/ for inspection
# in every non-zero path, and let the user retry from a clean
# start. See DESIGN.md 'Base System Maintenance' for the ext4
# unclean-shutdown rationale.
#
# 143 is called out specifically because it is the common case: a
# 'virtdev-stop maintenance' whose ACPI powerdown timed out and
# fell back to SIGTERM, a 'systemctl --user stop
# virtdev-maintenance', or an external kill -TERM all route here.
# The message distinguishes the likely cause and explains why
# SIGTERM-to-QEMU is not equivalent to a guest-level shutdown —
# users who don't know the distinction are tempted to just say
# 'y' to a reseal prompt, so we refuse the prompt entirely and
# tell them how to redo the session cleanly.
case "${qemu_exit}" in
  0)
    : # Clean guest poweroff. Fall through to the reseal prompt below.
    ;;
  143)
    error 11 <<MESSAGE
Maintenance virtual machine exited abnormally.
Unit exit status: 143 (SIGTERM).

Likely cause:

    virtdev-stop maintenance       (ACPI powerdown fallback to SIGTERM)
    systemctl --user stop virtdev-maintenance
    kill -TERM <qemu-pid>

SIGTERM tells QEMU to shut ITSELF down cleanly — flush qcow2
buffers, close file handles — but does not give the guest
operating system a chance to run its own shutdown. From the
guest kernel's perspective this is an abrupt power-off:
ext4's journal is dirty, the page cache is lost, and any
in-progress package transactions are half-applied. Resealing
in this state would bake that dirty state into the new base.

The sealed base images are intact: '${system_directory}'
Maintenance images preserved for inspection: '${maintenance_directory}'

Discard the staging directory and re-enter maintenance:

    rm -rf '${maintenance_directory}'
    virtdev-maintain

Inside the VM, finish with 'sudo poweroff' — that triggers a
proper guest-level shutdown and QEMU will then exit 0.
MESSAGE
    ;;
  *)
    error 11 <<MESSAGE
Maintenance virtual machine exited abnormally.
Unit exit status: ${qemu_exit}

This is not a clean guest poweroff. Whatever happened may have
left the guest filesystem in an inconsistent state (dirty ext4
journal, half-applied writes). Resealing is refused.

The sealed base images are intact: '${system_directory}'
Maintenance images preserved for inspection: '${maintenance_directory}'
Remove manually to retry: rm -rf '${maintenance_directory}'
MESSAGE
    ;;
esac

# qemu_exit == 0 only confirms the QEMU process exited without a
# signal — it does not prove the guest actually ran its shutdown
# sequence rather than being, say, manually 'exit 0' from a
# foreground shell inside the guest. Require explicit user
# confirmation before overwriting the sealed base system.
printf 'Virtual machine exited cleanly.\n'
printf 'Reseal the base system? [y/N] '
read -r confirm
if [[ "${confirm}" != 'y' && "${confirm}" != 'Y' ]]; then
  error 12 <<MESSAGE
Reseal cancelled.
The sealed base images are intact: '${system_directory}'
Maintenance images preserved for inspection: '${maintenance_directory}'
Remove manually to retry: rm -rf '${maintenance_directory}'
MESSAGE
fi

printf 'Checking maintenance image integrity...\n'
if ! qemu-img check -q "${system_disk}"; then
  error 13 <<<"System disk integrity check failed: '${system_disk}'"
fi
if ! qemu-img check -q "${home_disk}"; then
  error 14 <<<"Home disk integrity check failed: '${home_disk}'"
fi

# Read and validate the old version counter BEFORE the rename
# sequence below. After the mv, the sealed base has moved to
# system.old and recovery from a corrupted version would be manual
# surgery; failing here leaves the sealed base untouched in place.
# Accept any non-negative integer, including 0, to stay consistent
# with the validation elsewhere — virtdev-seal writes the initial
# counter as '1' but the schema itself does not require that.
old_version=1
if [[ -f "${system_directory}/version" ]]; then
  old_version="$(< "${system_directory}/version")"
  if ! [[ "${old_version}" =~ ^[0-9]+$ ]]; then
    error 15 <<MESSAGE
Corrupted base version file: '${system_directory}/version'
Contents: '${old_version}'
Repair manually: the file must contain a single non-negative integer.
The sealed base images are intact: '${system_directory}'
Maintenance images preserved for inspection: '${maintenance_directory}'
MESSAGE
  fi
fi

# Reseal:
#
#     1. Rename old system directory aside
#     2. Rename maintenance/ directory to system/
#     3. Write new version counter
#     4. chmod 444 to seal
#     5. Atomically rename system.old/ to system.old.trash/ (commit)
#     6. Outside the trap: rm -rf the trash (best-effort cleanup)
#
# Steps 1–5 are the non-atomic critical section. Between the
# operations the layout is transiently inconsistent: no system/
# (between the two mv's); system/ without a version file (post-mv,
# pre-write); system/ not yet read-only (post-write, pre-chmod); or
# a leftover system.old/ alongside a fully-sealed system/ (pre-step-5).
# Catchable signals — Ctrl-C, SIGTERM from systemctl --user stop,
# HUP from a closed terminal — are trapped away for the duration so
# those paths cannot interrupt the sequence partway through.
#
# Step 5 (mv system.old → system.old.trash) is the commit point.
# Auto-recovery treats "system.old/ exists" as "interrupted reseal,
# revert" — but it ignores trash_directory, which it just removes
# as cleanup. A single rename(2) is atomic on a single filesystem,
# so the transition from "system.old/ exists (revert on recovery)"
# to "trash/ exists (cleanup on recovery)" is one syscall: there is
# no in-between state where a crash could leave both visible to a
# later auto-recovery. Step 6's rm is therefore best-effort: if it
# fails, the trash lingers as garbage and is collected by the next
# maintain run's auto-recovery, but the new base is already
# committed and cannot revert.
#
# SIGKILL and hardware failure still get through — nothing can
# trap SIGKILL — but the auto-recovery handles the resulting state
# correctly: a SIGKILL before step 5 leaves system.old/ and reverts;
# after step 5 leaves trash and just cleans up. The only loss is
# the in-progress maintenance work itself if the kill lands before
# step 5, which the user has to redo. A syscall-level atomic
# RENAME_EXCHANGE (renameat2, Linux-only) would close even the
# brief mid-step-1/2/3/4 window but is not wrapped by any
# shell-accessible tool today.
trap '' INT TERM HUP QUIT
printf "Resealing base system images to: '%s'\n" "${system_directory}"
mv "${system_directory}" "${old_system_directory}"
mv "${maintenance_directory}" "${system_directory}"

printf 'Incrementing version counter (%d → %d)...\n' \
       "${old_version}" "$(( old_version + 1 ))"
printf '%d\n' "$(( old_version + 1 ))" > "${system_directory}/version"

printf 'Marking base system images read-only...\n'
chmod 444 "${system_directory}"/*

mv "${old_system_directory}" "${trash_directory}"
trap - INT TERM HUP QUIT

# Best-effort trash removal. Failure here does not affect
# correctness: the next maintain run's auto-recovery will collect
# any leftover trash directory. Surface a warning so the user knows
# disk space is being held until then.
if ! rm -rf "${trash_directory}"; then
  printf >&2 'warning: could not remove %s; will be cleaned up on next virtdev-maintain run\n' \
             "${trash_directory}"
fi

printf 'Base system resealed: %s\n' "${system_directory}"
printf '\n'
printf 'Project virtual machines in delta mode do not inherit these changes.\n'
printf 'Recreate them with virtdev-destroy + virtdev-create to pick up updates.\n'
