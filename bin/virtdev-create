#!/usr/bin/env bash
#
# virtdev-create <project>
#
# Creates a named project virtual machine
# derived from the sealed base system images.
# Provisions the project directory.
# Does not start the virtual machine
# nor assign an SSH port.
# Use virtdev-start for that.
#
# Project layout:
#
#   ${VIRTDEV_HOME}/
#     projects/
#       ${project}/
#         system.qcow2    (delta over system/system.qcow2)
#         home.qcow2      (delta over system/home.qcow2)
#         nvram           (UEFI variable store copy)
#

set -euo pipefail

error() {
  local -r code="${1}"
  cat >&2
  exit "${code}"
}

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"

if [[ $# -ne 1 ]]; then
  error 1 <<<'usage: virtdev-create <project>'
fi

project="${1}"

if [[ ! "${project}" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  error 2 <<MESSAGE
Invalid project name: '${project}'
Allowed: a-z A-Z 0-9 _ -
MESSAGE
fi

if [[ "${project}" == "maintenance" ]]; then
  error 3 <<<"Project name 'maintenance' is reserved by virtdev-maintain"
fi

# Acquire the exclusive virtdev lock. See virtdev-install for the
# full rationale.
mkdir -p "${VIRTDEV_HOME}"
exec 9>>"${VIRTDEV_HOME}/lock"
if ! flock -n 9; then
  holder_pid="$(cat "${VIRTDEV_HOME}/lock" 2>/dev/null || true)"
  holder_cmdline=""
  if [[ -n "${holder_pid}" && -r "/proc/${holder_pid}/cmdline" ]]; then
    holder_cmdline="$(tr '\0' ' ' < "/proc/${holder_pid}/cmdline")"
  fi
  if [[ "${holder_cmdline}" == *virtdev-maintain* ]]; then
    error 7 <<MESSAGE
Base system maintenance is in progress (virtdev-maintain, PID ${holder_pid}).
Wait for it to finish or inspect its virtual machine:
    systemctl --user status virtdev-maintenance
MESSAGE
  fi
  error 7 <<MESSAGE
Another virtdev operation is in progress.
Lock file: ${VIRTDEV_HOME}/lock
Holder PID: ${holder_pid:-unknown}
MESSAGE
fi
: > "${VIRTDEV_HOME}/lock"
printf '%d\n' "$$" >&9

system_directory="${VIRTDEV_HOME}/system"
projects_directory="${VIRTDEV_HOME}/projects"
project_directory="${projects_directory}/${project}"

if [[ ! -d "${system_directory}" ]]; then
  error 4 <<MESSAGE
Sealed base system images not found: '${system_directory}'
Run virtdev-install and virtdev-seal first
MESSAGE
fi

for file in system.qcow2 home.qcow2 nvram; do
  if [[ ! -f "${system_directory}/${file}" ]]; then
    error 5 <<<"Base system image missing: '${system_directory}/${file}'"
  fi
done

if [[ -d "${project_directory}" ]]; then
  error 6 <<<"Project already exists: '${project_directory}'"
fi

# Create project directory and disk images.
# Any failure between here and the final success marker deletes the
# partial directory so the user can retry without manual cleanup.

mkdir -p "${project_directory}"

create_succeeded=0
cleanup_partial_project() {
  (( create_succeeded )) || rm -rf "${project_directory}"
}
trap cleanup_partial_project EXIT

system_disk="${project_directory}/system.qcow2"
home_disk="${project_directory}/home.qcow2"
nvram="${project_directory}/nvram"

printf "Creating system delta image: '%s'\n" "${system_disk}"
qemu-img create \
    -f qcow2 \
    -b "${system_directory}/system.qcow2" \
    -F qcow2 \
    "${system_disk}"

printf "Creating home delta image: '%s'\n" "${home_disk}"
qemu-img create \
    -f qcow2 \
    -b "${system_directory}/home.qcow2" \
    -F qcow2 \
    "${home_disk}"

printf "Copying NVRAM: '%s'\n" "${nvram}"
cp "${system_directory}/nvram" "${nvram}"
chmod 644 "${nvram}"

if [[ -f "${system_directory}/version" ]]; then
  cp "${system_directory}/version" "${project_directory}/version"
fi

create_succeeded=1

printf '\n'
printf "Project virtual machine created: '%s'\n" "${project}"
printf "Directory: '%s'\n" "${project_directory}"
printf "Start it with: virtdev-start %s\n" "${project}"
