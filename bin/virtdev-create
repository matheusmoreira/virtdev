#!/usr/bin/env bash
#
# virtdev-create <project>
#
# Creates a named project virtual machine
# derived from the sealed base system images.
# Provisions the project directory.
# Does not start the virtual machine
# nor assign an SSH port.
# Use virtdev-start for that.
#
# Project layout:
#
#   ${VIRTDEV_HOME}/
#     projects/
#       ${project}/
#         system.qcow2    (delta over system/system.qcow2)
#         home.qcow2      (delta over system/home.qcow2)
#         nvram           (UEFI variable store copy)
#

set -euo pipefail

# shellcheck disable=SC1090,SC1091
source "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev/import"

import error validate lock arguments terminal

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"

# shellcheck disable=SC2034  # spec/companions read via nameref
declare -A spec=()
# shellcheck disable=SC2034
declare -a spec_positionals=(project)
# shellcheck disable=SC2034
declare -A flags=()
declare -a positional=()
arguments_parse spec flags positional "$@"
set -- "${positional[@]}"

if [[ $# -ne 1 ]]; then
  error 64 <<<"$(arguments_usage spec)"
fi

project="${1}"

validate_project_name "${project}"

if [[ "${project}" == "maintenance" ]]; then
  error 3 <<<"Project name 'maintenance' is reserved by virtdev-maintain"
fi

lock_acquire

system_directory="${VIRTDEV_HOME}/system"
projects_directory="${VIRTDEV_HOME}/projects"
project_directory="${projects_directory}/${project}"

if [[ ! -d "${system_directory}" ]]; then
  error 4 <<MESSAGE
Sealed base system images not found: '${system_directory}'
Run virtdev-install and virtdev-seal first
MESSAGE
fi

for file in system.qcow2 home.qcow2 nvram; do
  if [[ ! -f "${system_directory}/${file}" ]]; then
    error 5 <<<"Base system image missing: '${system_directory}/${file}'"
  fi
done

# Validate the base generation file if present, so a corrupt base fails
# at create time instead of start time. virtdev-start's comparison
# is strict; inheriting a corrupted counter here would produce a
# project that can never boot.
if [[ -f "${system_directory}/generation" ]]; then
  base_generation="$(< "${system_directory}/generation")"
  if ! [[ "${base_generation}" =~ ^[0-9]+$ ]]; then
    error 7 <<MESSAGE
Corrupted base generation file: '${system_directory}/generation'
Contents: '${base_generation}'
Repair manually: the file must contain a single non-negative integer.
MESSAGE
  fi
fi

if [[ -d "${project_directory}" ]]; then
  error 6 <<<"Project already exists: '${project_directory}'"
fi

# Create project directory and disk images.
# Any failure between here and the final success marker deletes the
# partial directory so the user can retry without manual cleanup.

mkdir -p "${project_directory}"

create_succeeded=0
cleanup_partial_project() {
  (( create_succeeded )) || rm -rf "${project_directory}"
}
trap cleanup_partial_project EXIT

system_disk="${project_directory}/system.qcow2"
home_disk="${project_directory}/home.qcow2"
nvram="${project_directory}/nvram"

printf >&2 "Creating system delta image: '%s'\n" "${system_disk}"
qemu-img create \
    -f qcow2 \
    -b "${system_directory}/system.qcow2" \
    -F qcow2 \
    "${system_disk}"

printf >&2 "Creating home delta image: '%s'\n" "${home_disk}"
qemu-img create \
    -f qcow2 \
    -b "${system_directory}/home.qcow2" \
    -F qcow2 \
    "${home_disk}"

printf >&2 "Copying NVRAM: '%s'\n" "${nvram}"
cp "${system_directory}/nvram" "${nvram}"
chmod 644 "${nvram}"

if [[ -f "${system_directory}/generation" ]]; then
  cp "${system_directory}/generation" "${project_directory}/generation"
  chmod 644 "${project_directory}/generation"
fi

create_succeeded=1

printf >&2 '\n'
printf >&2 '%s\n' "$(terminal_write fg=green "Project virtual machine created: '${project}'" reset)"
printf >&2 "Directory: '%s'\n" "${project_directory}"
printf >&2 "Start it with: virtdev-start %s\n" "${project}"