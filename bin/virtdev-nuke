#!/usr/bin/env bash
#
# virtdev-nuke
#
# Permanently deletes all virtdev data:
#
#   ${VIRTDEV_HOME}                                   (projects, images, keys)
#   ${XDG_CACHE_HOME:-~/.cache}/virtdev               (ISO, build artifacts)
#
# No other paths are touched. Ever.
#
# All project virtual machines must be stopped before running this.
# Requires typing "nuke" to confirm.
# This operation is irreversible.
#

set -euo pipefail

virtdev_library_directory="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev"
declare -A virtdev_loaded_libraries=()
import() {
  local f
  for f in "$@"; do
    [[ -v virtdev_loaded_libraries[$f] ]] && continue
    virtdev_loaded_libraries[$f]=1
    # shellcheck disable=SC1090
    source -p "${virtdev_library_directory}" "${f}"
  done
}

import error lock

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"
: "${VIRTDEV_CACHE:="${XDG_CACHE_HOME:-${HOME}/.cache}/virtdev"}"

if [[ $# -ne 0 ]]; then
  error 1 <<<'usage: virtdev-nuke'
fi

# Refuse to operate on any path that is not strictly under $HOME.
# This guards against a typo or accidental override of VIRTDEV_HOME or
# VIRTDEV_CACHE turning 'nuke' into 'rm -rf /usr' or similar.
# Using realpath -m resolves symlinks so the check applies to the
# physical target, not the link path.
home_real="$(realpath "${HOME}")"
for path in "${VIRTDEV_HOME}" "${VIRTDEV_CACHE}"; do
  real="$(realpath -m "${path}")"
  if [[ "${real}" != "${home_real}"/?* ]]; then
    error 2 <<MESSAGE
Path is not strictly under \$HOME: '${path}'
	Resolved: '${real}'
	Home:     '${home_real}'
Nuke aborted.
MESSAGE
  fi
done

# Taken BEFORE the "any VMs active" check below so a concurrent
# virtdev-start cannot slip a VM in between the check and the rm -rf.
lock_acquire

# Refuse if any project VMs are running
projects_directory="${VIRTDEV_HOME}/projects"
if [[ -d "${projects_directory}" ]]; then
  while IFS= read -r project; do
    if systemctl --user --quiet is-active virtdev-"${project}" 2>/dev/null; then
      error 3 <<MESSAGE
Project virtual machine is running: ${project}
Stop it with: virtdev-stop ${project}
All virtual machines must be stopped before nuking
MESSAGE
    fi
  done < <(find "${projects_directory}" -maxdepth 1 -mindepth 1 -type d -printf '%f\n' 2>/dev/null)
fi

printf 'This will permanently delete all virtdev data:\n\n'

for path in "${VIRTDEV_HOME}" "${VIRTDEV_CACHE}"; do
  if [[ -e "${path}" ]]; then
    printf '\t%s\t%s\n' "$(du -sh "${path}" 2>/dev/null | cut -f1)" "${path}"
  fi
done

backups_root="${VIRTDEV_HOME}/backups"
if [[ -d "${backups_root}" ]]; then
  mapfile -t backup_projects < <(
    find "${backups_root}" -maxdepth 1 -mindepth 1 -type d -printf '%f\n' 2>/dev/null \
      | sort
  )
  if (( ${#backup_projects[@]} > 0 )); then
    printf '\nBackup snapshots:\n'
    for bp in "${backup_projects[@]}"; do
      bp_dir="${backups_root}/${bp}"
      count=$(
        find "${bp_dir}" -mindepth 2 -maxdepth 2 -type d \
             -regextype posix-extended \
             -regex '.*/[0-9]{4}-[0-9]{2}-[0-9]{2}/[0-9]{2}-[0-9]{2}-[0-9]{2}' \
          2>/dev/null \
          | wc -l
      )
      size="$(du -sh "${bp_dir}" 2>/dev/null | cut -f1)"
      printf '\t%s\t%s\t(%d snapshots)\n' "${size}" "${bp_dir}" "${count}"
    done
  fi
fi

printf '\nThis includes:\n'
printf '\tALL project virtual machines\n'
printf '\tALL disk images\n'
printf '\tALL backup snapshots\n'
printf '\tBase system images\n'
printf '\tSSH keys\n'
printf '\tISOs\n'
printf '\nThis operation is irreversible.\n'
printf 'Type "nuke" to confirm: '
read -r confirmation

if [[ "${confirmation}" != "nuke" ]]; then
  error 4 <<<"Aborted."
fi

[[ -d "${VIRTDEV_HOME}"  ]] && rm -rf "${VIRTDEV_HOME}"
[[ -d "${VIRTDEV_CACHE}" ]] && rm -rf "${VIRTDEV_CACHE}"

printf 'All virtdev data deleted.\n'
