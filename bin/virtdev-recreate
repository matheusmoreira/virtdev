#!/usr/bin/env bash
# shellcheck disable=SC2154  # virtdev_bin_directory provided by lib/virtdev/import
#
# virtdev-recreate [--provision <path>] [--no-backup] [--no-restore]
#                  [--no-provision] [--yes] [--verbose] <project>
#
# Takes a project virtual machine through the destroy/rebuild cycle
# without losing user-curated state. Composes the existing virtdev
# primitives into a single operation gated by one type-the-name
# confirmation prompt.
#
# The chain (with all defaults):
#
#     1. virtdev-backup        snapshot home-disk state to backups/
#     2. virtdev-stop          ACPI shutdown
#     3. virtdev-destroy --yes wipe project disks
#     4. virtdev-create        rebuild on the current sealed base
#     5. virtdev-start         boot the fresh VM
#     6. virtdev-wait          wait for SSH to come up
#     7. provision             optional: bash -s the provision script
#     8. virtdev-restore       overlay the snapshot from step 1
#
# Provision discovery (resolves a script path or skips):
#
#     1. --no-provision        kill switch wins
#     2. --provision <path>    explicit path; precondition-checked
#     3. ${XDG_CONFIG_HOME:-~/.config}/virtdev/projects/<name>/provision
#     4. otherwise: no provision step
#
# Provision execution: virtdev-ssh <project> bash -s < <path>. The
# script is interpreted as bash (the shebang is ignored). Working
# directory is the dev user's /home/dev/. Wrap other interpreters
# from a one-line bash launcher.
#
# Lock model: recreate does NOT take the virtdev lock at the top
# level. Each subcommand takes the lock as needed (stop, destroy,
# create, start). Backup, restore, wait, and provision do not. This
# avoids holding the lock across the slow rsync transfers in backup
# and restore. The narrow inter-step race windows are documented in
# DESIGN.md; the snapshot is the durable artifact across all
# realistic failures.
#
# Failure semantics: fail-fast at any non-zero subcommand exit. The
# exit code identifies which step failed (20 backup, 21 stop, 22
# destroy, 23 create, 24 start, 25 wait, 26 provision, 27 restore);
# the message names the recovery command for that boundary.
#
# Configuration via environment variables:
#
#   VIRTDEV_HOME    Default: ${XDG_DATA_HOME:-~/.local/share}/virtdev
#

set -euo pipefail

# shellcheck disable=SC1090,SC1091
source "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev/import"

import error validate arguments snapshot manifest confirm terminal

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"
: "${XDG_CONFIG_HOME:="${HOME}/.config"}"

# shellcheck disable=SC2034  # spec/companions read via nameref
declare -A spec=(
  [provision]=value
  [no-backup]=bool
  [no-restore]=bool
  [no-provision]=bool
  [yes]=bool
  [verbose]=bool
)
# shellcheck disable=SC2034
declare -A spec_short=([p]=provision [y]=yes [v]=verbose)
# shellcheck disable=SC2034
declare -A spec_placeholders=([provision]=path)
# shellcheck disable=SC2034
declare -a spec_positionals=(project)
declare -A flags=()
declare -a positional=()
arguments_parse spec flags positional "$@"
set -- "${positional[@]}"

if [[ $# -ne 1 ]]; then
  error 64 <<<"$(arguments_usage spec)"
fi

project="${1}"

validate_project_name "${project}"

unit="virtdev-${project}"
project_directory="${VIRTDEV_HOME}/projects/${project}"
backups_project_dir="$(snapshot_directory "${project}")"

if [[ ! -d "${project_directory}" ]]; then
  error 3 <<<"Project not found: ${project}"
fi

# Capture VM state once. Used for both the precondition check (which
# requires it active unless --no-backup) and the do_stop decision
# (skip stop when the VM is already down).
unit_active=0
if systemctl --user --quiet is-active "${unit}" 2>/dev/null; then
  unit_active=1
fi

if (( ! flags[no-backup] )); then
  if (( ! unit_active )); then
    error 4 <<MESSAGE
Virtual machine is not running: ${project}
Recreate must take a backup first, which requires SSH into the VM.
Either start it with:    virtdev-start ${project}
Or skip the backup with: virtdev-recreate --no-backup ${project}
MESSAGE
  fi

  if ! manifest_resolve "${project}" >/dev/null; then
    error 5 <<MESSAGE
Backup manifest not found at either of:
    ${project_directory}/manifest
    ${XDG_CONFIG_HOME}/virtdev/projects/${project}/manifest
Create one with paths to back up (one per line; '#' comments allowed).
Or skip the backup with: virtdev-recreate --no-backup ${project}
MESSAGE
  fi

  manifest_path="$(manifest_resolve "${project}")"
  if ! manifest_has_entries "${manifest_path}"; then
    error 5 <<MESSAGE
Backup manifest is empty (no non-blank, non-comment lines):
    ${manifest_path}
Add at least one path. Or skip the backup with:
    virtdev-recreate --no-backup ${project}
MESSAGE
  fi
fi

# Provision resolution. The kill switch wins; the flag wins over the
# hook; the hook wins over nothing. Echoed to stderr at execution time
# so the user can spot which path actually ran.
provision_path=""
if (( ! flags[no-provision] )); then
  if [[ -n "${flags[provision]}" ]]; then
    if [[ ! -f "${flags[provision]}" || ! -r "${flags[provision]}" ]]; then
      error 6 <<MESSAGE
Provision script not found or not readable: ${flags[provision]}
MESSAGE
    fi
    provision_path="${flags[provision]}"
  else
    provision_hook="${XDG_CONFIG_HOME}/virtdev/projects/${project}/provision"
    if [[ -f "${provision_hook}" && -r "${provision_hook}" ]]; then
      provision_path="${provision_hook}"
    fi
  fi
fi

# Snapshot inventory: needed for the "skip restore when --no-backup
# and no prior snapshots" rule, and for the latest-snapshot reference
# in restore-failure recovery hints.
has_snapshots=0
snapshot_any "${project}" && has_snapshots=1

# Decide which steps will actually run. Computed up front so the plan
# print is accurate and the chain executes without re-deriving.
do_backup=$((    ! flags[no-backup] ))
do_stop=$((      unit_active ))
do_provision=0
[[ -n "${provision_path}" ]] && do_provision=1
do_restore=$((   ! flags[no-restore] ))

# Restore needs something to restore from. If we are taking a backup
# this run, that supplies it. If we are not (--no-backup), fall back
# to any prior snapshot; if there are none, skip restore.
restore_skip_reason=""
if (( do_restore )); then
  if (( ! do_backup )) && (( ! has_snapshots )); then
    do_restore=0
    restore_skip_reason="no prior snapshots"
  fi
fi

# Plan print. Active steps are numbered contiguously; skipped steps
# show -- instead of a number. The user reads this immediately before
# being asked to type the project name to confirm.
total_steps=$(( 4 + do_backup + do_stop + do_provision + do_restore ))
{
  printf '\n'
  printf 'Plan for recreate of %s:\n' "${project}"
  step=0
  if (( do_backup )); then
    printf '  %d. backup\n' "$(( ++step ))"
  else
    printf '  -- backup        (skipped: --no-backup)\n'
  fi
  if (( do_stop )); then
    printf '  %d. stop\n' "$(( ++step ))"
  else
    printf '  -- stop          (skipped: VM already stopped)\n'
  fi
  printf '  %d. destroy --yes\n' "$(( ++step ))"
  printf '  %d. create\n'        "$(( ++step ))"
  printf '  %d. start\n'         "$(( ++step ))"
  printf '  %d. wait\n'          "$(( ++step ))"
  if (( do_provision )); then
    printf '  %d. provision     %s\n' "$(( ++step ))" "${provision_path}"
  elif (( flags[no-provision] )); then
    printf '  -- provision     (skipped: --no-provision)\n'
  else
    printf '  -- provision     (skipped: no script found)\n'
  fi
  if (( do_restore )); then
    if (( do_backup )); then
      printf '  %d. restore       (latest snapshot from step 1)\n' "$(( ++step ))"
    else
      printf '  %d. restore       (latest existing snapshot)\n' "$(( ++step ))"
    fi
  elif (( flags[no-restore] )); then
    printf '  -- restore       (skipped: --no-restore)\n'
  else
    printf '  -- restore       (skipped: %s)\n' "${restore_skip_reason}"
  fi
  printf '\n'
  printf 'This is irreversible.\n'
} >&2

if (( ! flags[yes] )); then
  if ! confirm_word "${project}"; then
    error 7 <<<'Aborted.'
  fi
fi

# Subcommand invocation goes through the resolved bin directory so the
# dev tree and the pacman-installed package both work without relying
# on PATH ordering (a user with both installed could otherwise mix
# versions inside a single recreate run).
backup() {
  local opts=()
  (( flags[verbose] )) && opts+=(--verbose)
  "${virtdev_bin_directory}/virtdev-backup" "${opts[@]}" "${project}"
}

stop() {
  "${virtdev_bin_directory}/virtdev-stop" "${project}"
}

destroy() {
  "${virtdev_bin_directory}/virtdev-destroy" --yes "${project}"
}

create() {
  "${virtdev_bin_directory}/virtdev-create" "${project}"
}

start() {
  "${virtdev_bin_directory}/virtdev-start" "${project}"
}

wait_ssh() {
  "${virtdev_bin_directory}/virtdev-wait" "${project}"
}

provision() {
  "${virtdev_bin_directory}/virtdev-ssh" "${project}" bash -s < "${provision_path}"
}

restore() {
  local opts=()
  (( flags[verbose] )) && opts+=(--verbose)
  "${virtdev_bin_directory}/virtdev-restore" "${opts[@]}" "${project}"
}

# Helper to point the user at the most recent snapshot in failure
# messages. Returns the snapshot's <date>/<time> path component, or
# the empty string if none exists.
latest_snapshot() {
  snapshot_latest "${project}"
}

# Chain execution. Each step prints its banner first so the user can
# see where they are in the plan; on failure the matching error block
# tells them what state the project is in now and which command to
# run by hand to resume.
step=0

if (( do_backup )); then
  (( ++step ))
  printf '\n%s\n' "$(terminal_write bold "[${step}/${total_steps}] backup" reset)" >&2
  if ! backup; then
    error 20 <<MESSAGE
backup failed (virtdev-backup exited non-zero).
Project ${project} is unchanged. Investigate the rsync output above
and rerun:
    virtdev-recreate ${project}
MESSAGE
  fi
fi

if (( do_stop )); then
  (( ++step ))
  printf '\n%s\n' "$(terminal_write bold "[${step}/${total_steps}] stop" reset)" >&2
  if ! stop; then
    snap="$(latest_snapshot)"
    snap_hint=""
    [[ -n "${snap}" ]] && snap_hint="
Snapshot from this run: ${backups_project_dir}/${snap}/"
    error 21 <<MESSAGE
stop failed (virtdev-stop exited non-zero).
The VM may be in an indeterminate state. Inspect with:
    systemctl --user status ${unit}
Stop it manually, then rerun with --no-backup (the snapshot is
already on disk):
    virtdev-stop ${project}
    virtdev-recreate --no-backup ${project}${snap_hint}
MESSAGE
  fi
fi

(( ++step ))
printf '\n%s\n' "$(terminal_write bold "[${step}/${total_steps}] destroy" reset)" >&2
if ! destroy; then
  snap="$(latest_snapshot)"
  snap_hint=""
  [[ -n "${snap}" ]] && snap_hint="
Snapshot is preserved at: ${backups_project_dir}/${snap}/"
  error 22 <<MESSAGE
destroy failed (virtdev-destroy exited non-zero).
The project still exists. Inspect, fix, and rerun with --no-backup:
    virtdev-recreate --no-backup ${project}${snap_hint}
MESSAGE
fi

(( ++step ))
printf '\n%s\n' "$(terminal_write bold "[${step}/${total_steps}] create" reset)" >&2
if ! create; then
  snap="$(latest_snapshot)"
  snap_hint=""
  [[ -n "${snap}" ]] && snap_hint="
Snapshot is preserved at: ${backups_project_dir}/${snap}/"
  error 23 <<MESSAGE
create failed (virtdev-create exited non-zero).
Project directory was destroyed but the new one was not built.
Investigate, then rerun with --no-backup:
    virtdev-recreate --no-backup ${project}${snap_hint}
MESSAGE
fi

(( ++step ))
printf '\n%s\n' "$(terminal_write bold "[${step}/${total_steps}] start" reset)" >&2
if ! start; then
  snap="$(latest_snapshot)"
  snap_hint=""
  [[ -n "${snap}" ]] && snap_hint="
Snapshot path: ${backups_project_dir}/${snap}/"
  error 24 <<MESSAGE
start failed (virtdev-start exited non-zero).
A fresh project exists for ${project} but is not running.
Resume manually:
    virtdev-start ${project}
    virtdev-wait ${project}
    virtdev-restore ${project}${snap_hint}
MESSAGE
fi

(( ++step ))
printf '\n%s\n' "$(terminal_write bold "[${step}/${total_steps}] wait" reset)" >&2
if ! wait_ssh; then
  snap="$(latest_snapshot)"
  snap_hint=""
  [[ -n "${snap}" ]] && snap_hint="
Snapshot path: ${backups_project_dir}/${snap}/"
  error 25 <<MESSAGE
wait failed (virtdev-wait exited non-zero).
The fresh VM is up at the systemd level but SSH did not come up
within the timeout. Inspect with:
    journalctl --user -u ${unit}
Once SSH is up, restore manually:
    virtdev-restore ${project}${snap_hint}
MESSAGE
fi

if (( do_provision )); then
  (( ++step ))
  printf '\n%s\n' "$(terminal_write bold "[${step}/${total_steps}] provision ${provision_path}" reset)" >&2
  if ! provision; then
    snap="$(latest_snapshot)"
    snap_hint=""
    [[ -n "${snap}" ]] && snap_hint="
Snapshot path: ${backups_project_dir}/${snap}/"
    error 26 <<MESSAGE
provision failed (script exited non-zero): ${provision_path}
The fresh VM is up; the guest is in whatever state the script left it.
Inspect, fix the script, and either re-run it manually:
    virtdev-ssh ${project} bash -s < ${provision_path}
Or finish the chain by hand:
    virtdev-restore ${project}${snap_hint}
MESSAGE
  fi
fi

if (( do_restore )); then
  (( ++step ))
  printf '\n%s\n' "$(terminal_write bold "[${step}/${total_steps}] restore" reset)" >&2
  if ! restore; then
    snap="$(latest_snapshot)"
    snap_hint=""
    [[ -n "${snap}" ]] && snap_hint="
Latest snapshot: ${backups_project_dir}/${snap}/
Retry with explicit snapshot:
    virtdev-restore ${project} ${snap}"
    error 27 <<MESSAGE
restore failed (virtdev-restore exited non-zero).
The fresh VM is up and provisioned but the snapshot was not
applied.${snap_hint}
MESSAGE
  fi
fi

printf '\n'
if (( do_restore )); then
  printf '%s\n' "$(terminal_write fg=green "Project recreated: ${project}" reset)"
else
  printf '%s\n' "$(terminal_write fg=green "Project recreated: ${project}" reset " (restore skipped)")"
fi