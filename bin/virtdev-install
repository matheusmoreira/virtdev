#!/usr/bin/env bash
#
# virtdev-install [iso]
#
# Boots the virtdev ISO in a temporary QEMU process to install
# the base system into fresh qcow2 disks. Does not daemonize,
# waits for the VM to power off which happens automatically
# on successful installation. Serial output is attached
# to the terminal so that progress is visible.
#
# If no ISO path is given, defaults to the ISO produced by virtdev-iso.
#
# Resulting disk images are placed in ${VIRTDEV_HOME}/installation.
# Use virtdev-seal to promote them to sealed base system images
# from which project virtual machines may be derived.
#
# Configuration via environment variables:
#
#   VIRTDEV_HOME              Default: ${XDG_DATA_HOME:-~/.local/share}/virtdev
#   VIRTDEV_ISO               Default: ${XDG_CACHE_HOME:-~/.cache}/virtdev/virtdev.iso
#   VIRTDEV_SYSTEM_DISK_SIZE  Default: 24G
#   VIRTDEV_HOME_DISK_SIZE    Default: 48G
#   VIRTDEV_VM_MEMORY         Default: 4096
#   VIRTDEV_VM_CPUS           Default: 4
#   OVMF_CODE                 Default: /usr/share/edk2/x64/OVMF_CODE.4m.fd
#   OVMF_VARS                 Default: /usr/share/edk2/x64/OVMF_VARS.4m.fd
#

set -euo pipefail

error() {
  local -r code="${1}"
  cat >&2
  exit "${code}"
}

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"
: "${VIRTDEV_ISO:="${XDG_CACHE_HOME:-${HOME}/.cache}/virtdev/virtdev.iso"}"
: "${VIRTDEV_SYSTEM_DISK_SIZE:=24G}"
: "${VIRTDEV_HOME_DISK_SIZE:=48G}"
: "${VIRTDEV_VM_MEMORY:=4096}"
: "${VIRTDEV_VM_CPUS:=4}"
: "${OVMF_CODE:="/usr/share/edk2/x64/OVMF_CODE.4m.fd"}"
: "${OVMF_VARS:="/usr/share/edk2/x64/OVMF_VARS.4m.fd"}"

if [[ $# -gt 1 ]]; then
  error 1 <<<'usage: virtdev-install [iso]'
fi

if [[ $# -eq 1 ]]; then
  VIRTDEV_ISO="${1}"
fi

if [[ ! -f "${VIRTDEV_ISO}" ]]; then
  error 2 <<<"ISO not found: '${VIRTDEV_ISO}'"
fi

if [[ ! -f "${OVMF_CODE}" ]]; then
  error 3 <<<"OVMF_CODE not found: '${OVMF_CODE}'"
fi

if [[ ! -f "${OVMF_VARS}" ]]; then
  error 4 <<<"OVMF_VARS not found: '${OVMF_VARS}'"
fi

installation_directory="${VIRTDEV_HOME}"/installation

if [[ -d "${installation_directory}" ]]; then
  error 5 <<MESSAGE
Installation directory already exists: '${installation_directory}'
Use virtdev-seal to seal the installation, or remove it manually to reinstall.
MESSAGE
fi

system_directory="${VIRTDEV_HOME}"/system

if [[ -d "${system_directory}" ]]; then
  error 6 <<MESSAGE
Sealed base system images already present: '${system_directory}'
Remove the system directory manually to reinstall.
MESSAGE
fi

mkdir -p "${installation_directory}"

# Any failure or interruption between here and the final success marker
# removes the partial installation directory so the user can retry
# virtdev-install without having to rm -rf by hand. QEMU returns 0 only
# on successful guest poweroff (archinstall-auto.service runs
# 'systemctl poweroff' on success); any other exit path indicates an
# incomplete install.
install_succeeded=0
cleanup_partial_installation() {
  (( install_succeeded )) || rm -rf "${installation_directory}"
}
trap cleanup_partial_installation EXIT

system_disk="${installation_directory}"/system.qcow2
printf "Creating %s system disk image: '%s'\n" \
       "${VIRTDEV_SYSTEM_DISK_SIZE}" "${system_disk}"
qemu-img create -f qcow2 "${system_disk}" "${VIRTDEV_SYSTEM_DISK_SIZE}"

home_disk="${installation_directory}"/home.qcow2
printf "Creating %s home disk: '%s'\n" \
       "${VIRTDEV_HOME_DISK_SIZE}" "${home_disk}"
qemu-img create -f qcow2 "${home_disk}" "${VIRTDEV_HOME_DISK_SIZE}"

nvram="${installation_directory}"/nvram
printf 'Copying default NVRAM...\n'
cp "${OVMF_VARS}" "${nvram}"

printf 'Booting installer with serial output attached.\n'
printf 'On success, the virtual machine will power off automatically.\n'
printf 'On failure, the shell will be accessible via the serial console.\n\n'

qemu-system-x86_64 \
    -enable-kvm \
    -cpu host \
    -machine q35 \
    -m "${VIRTDEV_VM_MEMORY}" \
    -smp "${VIRTDEV_VM_CPUS}" \
    -drive if=pflash,format=raw,readonly=on,file="${OVMF_CODE}" \
    -drive if=pflash,format=raw,file="${nvram}" \
    -drive file="${system_disk}",if=virtio,format=qcow2 \
    -drive file="${home_disk}",if=virtio,format=qcow2 \
    -cdrom "${VIRTDEV_ISO}" \
    -boot order=d,menu=off \
    -netdev user,id=net0 \
    -device virtio-net-pci,netdev=net0 \
    -device virtio-rng-pci \
    -display none \
    -serial stdio \
    -monitor none

install_succeeded=1

printf '\n'
printf 'Installer finished.\n'
printf 'Run virtdev-seal to seal the base system images.\n'
