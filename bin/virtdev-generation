#!/usr/bin/env bash
#
# virtdev-generation [project]
#
# Prints the base system generation, or a project's generation.
# Machine-readable: stdout contains only the generation string.
#
# Without arguments: prints the sealed base generation (integer).
# With a project: prints the project's generation (integer or 'detached').
#

set -euo pipefail

# shellcheck disable=SC1090,SC1091
source "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev/import"

import error validate arguments

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"

# shellcheck disable=SC2034  # spec/companions read via nameref
declare -A spec=()
# shellcheck disable=SC2034
declare -a spec_positionals=("project?")
# shellcheck disable=SC2034
declare -A flags=()
declare -a positional=()
arguments_parse spec flags positional "$@"
set -- "${positional[@]}"

if [[ $# -gt 1 ]]; then
  error 64 <<<"$(arguments_usage spec)"
fi

if [[ $# -eq 0 ]]; then
  generation_file="${VIRTDEV_HOME}/system/generation"
  if [[ ! -f "${generation_file}" ]]; then
    error 3 <<<"Base system generation file not found: '${generation_file}'"
  fi
  printf '%s\n' "$(< "${generation_file}")"
  exit 0
fi

project="${1}"

validate_project_name "${project}"

project_directory="${VIRTDEV_HOME}/projects/${project}"

if [[ ! -d "${project_directory}" ]]; then
  error 3 <<<"Project not found: ${project}"
fi

generation_file="${project_directory}/generation"
if [[ ! -f "${generation_file}" ]]; then
  error 4 <<<"Generation file not found: '${generation_file}'"
fi

printf '%s\n' "$(< "${generation_file}")"
