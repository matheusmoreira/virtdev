#!/usr/bin/env bash
#
# virtdev-iso
#
# Builds the virtdev Arch Linux installation ISO.
# The resulting ISO is written to the current directory.
#
# Configuration via environment variables:
#
#   VIRTDEV_HOME           Base directory for virtdev data.
#                          Default: ${XDG_DATA_HOME:-~/.local/share}/virtdev
#
#   VIRTDEV_SSH_KEY        Path to the ed25519 private key whose public half
#                          is injected into the ISO as the authorized key for dev.
#                          Default: ${VIRTDEV_HOME}/ssh/id
#                          Run virtdev-key to generate it.
#
#   VIRTDEV_TIMEZONE       Timezone for the installed system.
#                          Default: UTC
#
#   VIRTDEV_ISO_PROFILE    Path to the virtdev ISO profile directory.
#                          Detected automatically; set to override.
#

set -euo pipefail

virtdev_library_directory="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev"
declare -A virtdev_loaded_libraries=()
import() {
  local f
  for f in "$@"; do
    [[ -v virtdev_loaded_libraries[$f] ]] && continue
    virtdev_loaded_libraries[$f]=1
    # shellcheck disable=SC1090
    source -p "${virtdev_library_directory}" "${f}"
  done
}

import error arguments

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"
: "${VIRTDEV_SSH_KEY:="${VIRTDEV_HOME}/ssh/id"}"
: "${VIRTDEV_TIMEZONE:="UTC"}"

# shellcheck disable=SC2034  # spec read via nameref
declare -A spec=()
case "${1:-}" in
  --help|-h) arguments_usage spec ; exit 0 ;;
esac
# shellcheck disable=SC2034
declare -A flags=()
declare -a positional=()
arguments_parse spec flags positional "$@"
set -- "${positional[@]}"

if [[ $# -ne 0 ]]; then
  error 64 <<<"$(arguments_usage spec)"
fi

#
# Resolve ISO profile directory:
#   1. Explicit override via VIRTDEV_ISO_PROFILE
#   2. Adjacent to script (git checkout: bin/../iso)
#   3. Installed system path (package: /usr/share/virtdev/profile)
#
script_dir="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
if [[ -n "${VIRTDEV_ISO_PROFILE:-}" ]]; then
  iso_profile="${VIRTDEV_ISO_PROFILE}"
elif [[ -f "${script_dir}/../iso/profiledef.sh" ]]; then
  iso_profile="$(cd "${script_dir}/../iso" && pwd -P)"
else
  iso_profile="/usr/share/virtdev/profile"
fi

if [[ ! -f "${iso_profile}/profiledef.sh" ]]; then
  error 3 <<<"ISO profile not found: '${iso_profile}'"
fi

if ! command -v mkarchiso &>/dev/null; then
  error 4 <<<'mkarchiso not found, install archiso'
fi

if ! command -v jq &>/dev/null; then
  error 5 <<<'jq not found, install jq'
fi

if [[ ! -f "${VIRTDEV_SSH_KEY}.pub" ]]; then
  error 6 <<MESSAGE
SSH public key not found: '${VIRTDEV_SSH_KEY}.pub'
Generate it with virtdev-key.
MESSAGE
fi

profile=/usr/share/archiso/configs/releng

if [[ ! -d "${profile}" ]]; then
  error 7 <<<"archiso releng profile not found: '${profile}'"
fi

public_key="$(< "${VIRTDEV_SSH_KEY}.pub")"

build_directory="${XDG_CACHE_HOME:-${HOME}/.cache}"/virtdev
output_directory="${build_directory}"
work_directory="${build_directory}"/work
profile_directory="${build_directory}"/profile

# Defense in depth around the privileged cleanup below. mkarchiso
# produces root-owned files in the work directory, so a naive cleanup
# would need sudo rm -rf on a path computed from environment variables.
# Three independent guards make a wrong-path delete extremely unlikely:
#
#   Layer 1: refuse if either rm target resolves outside $HOME. Catches
#            HOME or XDG_CACHE_HOME pointed somewhere unexpected.
#   Layer 2: refuse if the work/profile suffixes do not match the
#            expected construction. Catches a future code bug that
#            would happen to land under $HOME but at the wrong path.
#   Layer 3: chown the targets to the invoking user, then plain rm.
#            A wrong-path chown is recoverable; a wrong-path rm -rf
#            is not. After chown, plain rm is bounded by user perms.

home_real="$(realpath "${HOME}")"
for path in "${work_directory}" "${profile_directory}"; do
  real="$(realpath -m "${path}")"
  if [[ "${real}" != "${home_real}"/?* ]]; then
    error 10 <<MESSAGE
Build path is not strictly under \$HOME: '${path}'
    Resolved: '${real}'
    Home:     '${home_real}'
ISO build aborted.
MESSAGE
  fi
done

if [[ "${work_directory}" != "${build_directory}/work" \
   || "${profile_directory}" != "${build_directory}/profile" ]]; then
  error 11 <<<"build path construction mismatch (internal bug)"
fi

printf 'Clearing build tree...\n'
[[ -e "${work_directory}"    ]] && sudo chown -R "${USER}:${USER}" "${work_directory}"
[[ -e "${profile_directory}" ]] && sudo chown -R "${USER}:${USER}" "${profile_directory}"
rm -rf "${work_directory:?}" "${profile_directory:?}"
mkdir -p "${work_directory}" "${profile_directory}"

printf "Copying profile: '%s'\n" "${profile}"
cp -r "${profile}/." "${profile_directory}/"
rm -rf "${profile_directory}/grub" \
       "${profile_directory}/syslinux" \
       "${profile_directory}/efiboot/loader/entries/"*.conf

printf 'Overlaying ISO configuration files...\n'
cp -r "${iso_profile}/." "${profile_directory}/"

printf 'Injecting SSH public key and timezone...\n'
config_json="${profile_directory}/airootfs/root/archinstall/config.json"
jq --arg key      "${public_key}"      \
   --arg timezone "${VIRTDEV_TIMEZONE}" \
   '.users[0].ssh_authorized_keys = [$key] | .timezone = $timezone' \
   "${config_json}" > "${config_json}.tmp"
mv "${config_json}.tmp" "${config_json}"

printf 'Creating Arch Linux installation media...\n'
sudo mkarchiso -v -w "${work_directory}" -o "${output_directory}" "${profile_directory}"


mapfile -t built_isos < <(find "${output_directory}" -maxdepth 1 -name '*-x86_64.iso')

if [[ ${#built_isos[@]} -eq 0 ]]; then
  error 8 <<<"Failed to create installation media in '${output_directory}'"
fi

if [[ ${#built_isos[@]} -gt 1 ]]; then
  error 9 <<<"Multiple ISOs found in '${output_directory}'"
fi

iso="${output_directory}/virtdev.iso"
mv "${built_isos[0]}" "${iso}"

printf "Created Arch Linux installation media: '%s'\n" "${iso}"
