#!/usr/bin/env bash
#
# virtdev-restore [--verbose] <project> [<date> [<time>]]
#
# Restores a backup snapshot into a running project virtual machine.
# The snapshot layout is produced by virtdev-backup and lives under:
#
#   ${VIRTDEV_HOME}/backups/<project>/<YYYY-MM-DD>/<HH-MM-SS>/
#
# With no date/time arguments, restores the newest snapshot for the
# project. With just a date, restores the newest time within that
# day. With both, restores that exact snapshot.
#
# List available snapshots with: virtdev-backup --list <project>
#
# Flags:
#
#   --verbose    Show rsync per-file progress.
#
# Destructive: overwrites guest files without prompting. Because
# rsync operates on a live, running VM, partial failures may leave
# the guest's filesystem with some restored files and some not. This
# matches virtdev-transfer's semantics.
#
# The project's virtual machine must be running.
#
# Requires rsync on both host and guest:
#
#     pacman -S rsync
#
# Configuration via environment variables:
#
#   VIRTDEV_HOME       Default: ${XDG_DATA_HOME:-~/.local/share}/virtdev
#   VIRTDEV_SSH_KEY    Default: ${VIRTDEV_HOME}/ssh/id
#

set -euo pipefail

error() {
  local -r code="${1}"
  cat >&2
  exit "${code}"
}

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"
: "${VIRTDEV_SSH_KEY:="${VIRTDEV_HOME}/ssh/id"}"

umask 077

verbose=0
while [[ $# -gt 0 ]]; do
  case "${1}" in
    --verbose) verbose=1; shift ;;
    --)        shift; break ;;
    -*)        error 1 <<<"unknown flag: ${1}" ;;
    *)         break ;;
  esac
done

if [[ $# -lt 1 || $# -gt 3 ]]; then
  error 1 <<<'usage: virtdev-restore [--verbose] <project> [<date> [<time>]]'
fi

project="${1}"
given_date="${2:-}"
given_time="${3:-}"

if [[ ! "${project}" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  error 2 <<MESSAGE
Invalid project name: '${project}'
Allowed: a-z A-Z 0-9 _ -
MESSAGE
fi

project_directory="${VIRTDEV_HOME}/projects/${project}"

if [[ ! -d "${project_directory}" ]]; then
  error 3 <<<"Project not found: ${project}"
fi

if ! systemctl --user --quiet is-active "virtdev-${project}" 2>/dev/null; then
  error 4 <<MESSAGE
Virtual machine is not running: ${project}
Start it with: virtdev-start ${project}
MESSAGE
fi

port_file="${project_directory}/port"
if [[ ! -f "${port_file}" ]]; then
  error 4 <<MESSAGE
Project has no port assigned: ${project}
Start the virtual machine first: virtdev-start ${project}
MESSAGE
fi
port="$(< "${port_file}")"

if [[ ! -f "${VIRTDEV_SSH_KEY}" ]]; then
  error 5 <<MESSAGE
SSH key not found: '${VIRTDEV_SSH_KEY}'
Place the private key at that path, link it, or set VIRTDEV_SSH_KEY.
MESSAGE
fi

key_permissions="$(stat -c '%a' "${VIRTDEV_SSH_KEY}")"
if [[ "${key_permissions}" != "600" && "${key_permissions}" != "400" ]]; then
  error 5 <<MESSAGE
SSH key permissions too open: '${VIRTDEV_SSH_KEY}' (${key_permissions})
Fix with: chmod 600 '${VIRTDEV_SSH_KEY}'
MESSAGE
fi

if ! command -v rsync &>/dev/null; then
  error 6 <<MESSAGE
rsync not found
Install it with: pacman -S rsync
MESSAGE
fi

backups_project_dir="${VIRTDEV_HOME}/backups/${project}"

date_regex='^[0-9]{4}-[0-9]{2}-[0-9]{2}$'
time_regex='^[0-9]{2}-[0-9]{2}-[0-9]{2}$'

# Validate user-supplied date/time shape up front. Distinct exit
# codes per error type — date-format (9), time-format (15) — so a
# scripted caller can branch on the cause without parsing stderr.
if [[ -n "${given_date}" && ! "${given_date}" =~ ${date_regex} ]]; then
  error 9 <<<"Invalid date format: '${given_date}' (expected YYYY-MM-DD)"
fi
if [[ -n "${given_time}" && ! "${given_time}" =~ ${time_regex} ]]; then
  error 15 <<<"Invalid time format: '${given_time}' (expected HH-MM-SS)"
fi

list_day_dirs() {
  if [[ ! -d "${backups_project_dir}" ]]; then return 0; fi
  find "${backups_project_dir}" -maxdepth 1 -mindepth 1 -type d -printf '%f\n' 2>/dev/null \
    | grep -E "${date_regex}" \
    | sort
}

list_time_dirs() {
  local -r day="${1}"
  find "${backups_project_dir}/${day}" -maxdepth 1 -mindepth 1 -type d -printf '%f\n' 2>/dev/null \
    | grep -E "${time_regex}" \
    | sort
}

# Resolve date component. Resolution failures get codes distinct
# from the syntactic ones above: 16 = date directory absent,
# 17 = date directory empty (no times under it), 18 = time directory
# absent within an existing date.
if [[ -z "${given_date}" ]]; then
  resolved_date="$(list_day_dirs | tail -n1)"
  if [[ -z "${resolved_date}" ]]; then
    error 8 <<MESSAGE
No snapshots for this project: ${project}
Create one with: virtdev-backup ${project}
MESSAGE
  fi
else
  if [[ ! -d "${backups_project_dir}/${given_date}" ]]; then
    error 16 <<<"Snapshot date not found: ${given_date}"
  fi
  resolved_date="${given_date}"
fi

# Resolve time component.
if [[ -z "${given_time}" ]]; then
  resolved_time="$(list_time_dirs "${resolved_date}" | tail -n1)"
  if [[ -z "${resolved_time}" ]]; then
    error 17 <<<"No snapshots on date ${resolved_date}"
  fi
else
  if [[ ! -d "${backups_project_dir}/${resolved_date}/${given_time}" ]]; then
    error 18 <<<"Snapshot time not found: ${resolved_date}/${given_time}"
  fi
  resolved_time="${given_time}"
fi

snapshot="${backups_project_dir}/${resolved_date}/${resolved_time}"

if [[ ! -f "${snapshot}/backup.list" ]]; then
  error 10 <<<"Snapshot missing backup.list: ${snapshot}"
fi
if [[ ! -d "${snapshot}/tree" ]]; then
  error 10 <<<"Snapshot missing tree/: ${snapshot}"
fi
if [[ ! -f "${snapshot}/project" ]]; then
  error 10 <<MESSAGE
Snapshot missing 'project' marker: ${snapshot}
This snapshot was likely produced by an older virtdev-backup that
did not record the source project, so cross-project restoration
cannot be verified. Refusing to proceed.
Re-run virtdev-backup to produce a snapshot with origin metadata.
MESSAGE
fi

# Refuse cross-project restoration. The snapshot records the project
# it was taken from; restoring it into a different project would
# silently overwrite that project's files with the source project's
# tree. backup.list paths are user-curated and may differ between
# projects; even when they overlap, the resulting filesystem is
# half-merged and impossible to audit after the fact.
snapshot_project="$(< "${snapshot}/project")"
if [[ "${snapshot_project}" != "${project}" ]]; then
  error 12 <<MESSAGE
Snapshot belongs to a different project.
	snapshot project: ${snapshot_project}
	target project:   ${project}
Snapshots are project-scoped; cross-project restoration is refused.
MESSAGE
fi

# Read and validate the project's current base version. A project
# whose VM is running was created against some sealed base, and the
# version file is the audit trail for which one. The file must be a
# single non-negative integer per the convention in virtdev-start,
# virtdev-create, and virtdev-maintain (see commit 4b82a64).
project_version_file="${project_directory}/version"
if [[ ! -f "${project_version_file}" ]]; then
  error 13 <<MESSAGE
Project version file missing: '${project_version_file}'
The project's audit trail is incomplete; refusing to proceed.
MESSAGE
fi
project_version="$(< "${project_version_file}")"
if ! [[ "${project_version}" =~ ^[0-9]+$ ]]; then
  error 13 <<MESSAGE
Corrupted project version file: '${project_version_file}'
Contents: '${project_version}'
Repair manually: the file must contain a single non-negative integer.
MESSAGE
fi

# Read the snapshot's recorded base version. Empty/absent is a
# legitimate 'unknown at backup time' (the base predated versioning
# or was missing); display as '-'. Anything non-empty must validate,
# otherwise the snapshot's audit trail is unreliable.
snapshot_version='-'
if [[ -s "${snapshot}/version" ]]; then
  snapshot_version="$(< "${snapshot}/version")"
  if ! [[ "${snapshot_version}" =~ ^[0-9]+$ ]]; then
    error 14 <<MESSAGE
Corrupted snapshot version file: '${snapshot}/version'
Contents: '${snapshot_version}'
The snapshot's base-version audit trail is unreadable.
MESSAGE
  fi
fi

# Display the version transition. Mismatch is the EXPECTED case in
# the destroy-recreate-restore workflow (snapshot taken under one
# base, restored under the next), so it is informational, not fatal.
# Same-version restoration is the rollback case.
printf >&2 'Restoring %s from %s/%s\n' \
    "${project}" "${resolved_date}" "${resolved_time}"
printf >&2 '  snapshot version: %s\n' "${snapshot_version}"
printf >&2 '  current version:  %s\n' "${project_version}"

printf -v ssh_command \
    'ssh -i %q -p %q -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR' \
    "${VIRTDEV_SSH_KEY}" "${port}"

rsync_opts=(-a --no-D --ignore-missing-args --stats)
(( verbose )) && rsync_opts+=(--info=progress2)

rsync_log="$(mktemp)"
trap 'rm -f "${rsync_log}"' EXIT

if ! rsync "${rsync_opts[@]}" \
    --files-from=<(grep -Ev '^\s*(#|$)' "${snapshot}/backup.list") \
    -e "${ssh_command}" \
    "${snapshot}/tree/" \
    "dev@127.0.0.1:/home/dev/" \
    | tee "${rsync_log}"; then
  # PIPESTATUS[0] is rsync's exit code, intact because pipefail makes
  # the pipeline's exit non-zero on rsync failure and the if-not
  # branch reads PIPESTATUS as its first operation. Distinguish the
  # partial-transfer codes (23, 24) from transport errors (255) and
  # everything else, since the implications for the user differ:
  # partial means the guest filesystem is half-merged; transport
  # usually means nothing was touched.
  rsync_exit="${PIPESTATUS[0]}"
  case "${rsync_exit}" in
    23|24)
      partial_count="$(awk -F: '/^Number of regular files transferred:/ {
        gsub(/[ ,]/, "", $2); print $2
      }' "${rsync_log}")"
      error 7 <<MESSAGE
rsync transfer of ${project} completed with errors (exit ${rsync_exit}).
${partial_count:-?} files restored; the rest were skipped or failed.
The guest filesystem is in a half-merged state — some paths now
match the snapshot and others retain their pre-restore contents.
See the per-file output above for which entries failed.
Re-run virtdev-restore to retry; rsync's incremental check will
skip files that already match.
MESSAGE
      ;;
    255)
      error 7 <<MESSAGE
rsync transfer failed during restore of ${project} (exit 255: transport).
The SSH connection to the guest could not be established or was lost.
The guest's filesystem was not modified.
Verify the VM is reachable, then retry:

    virtdev-ssh ${project} true
    virtdev-restore ${project}
MESSAGE
      ;;
    *)
      error 7 <<MESSAGE
rsync transfer failed during restore of ${project} (exit ${rsync_exit}).
The transfer aborted before completion. See the per-file output
above for the cause. The guest filesystem may be unmodified or
partially modified — verify the state before retrying.
MESSAGE
      ;;
  esac
fi

files_transferred="$(awk -F: '/^Number of regular files transferred:/ {
  gsub(/[ ,]/, "", $2); print $2
}' "${rsync_log}")"
files_transferred="${files_transferred:-0}"

if (( files_transferred == 0 )); then
  error 11 <<MESSAGE
Zero files restored from snapshot: ${resolved_date}/${resolved_time}
The snapshot may be empty, or every path in its manifest is absent.
MESSAGE
fi

printf 'Restored %d files from %s/%s into %s.\n' \
    "${files_transferred}" "${resolved_date}" "${resolved_time}" "${project}"
