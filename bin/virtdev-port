#!/usr/bin/env bash
#
# virtdev-port <project> <port>
#
# Reassigns the SSH forwarding port of a stopped project virtual machine.
# The project must not be running.
#

set -euo pipefail

error() {
  local -r code="${1}"
  cat >&2
  exit "${code}"
}

port_in_use() {
  [[ -n "$(ss -tlnH "sport = :${1}" 2>/dev/null)" ]]
}

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"

if [[ $# -ne 2 ]]; then
  error 1 <<<'usage: virtdev-port <project> <port>'
fi

project="${1}"
port="${2}"

if [[ ! "${project}" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  error 2 <<MESSAGE
Invalid project name: '${project}'
Allowed: a-z A-Z 0-9 _ -
MESSAGE
fi

if [[ ! "${port}" =~ ^[0-9]+$ ]] || (( port < 1024 || port > 65535 )); then
  error 3 <<MESSAGE
Invalid port: '${port}'
Port must be between 1024 and 65535
MESSAGE
fi

projects_directory="${VIRTDEV_HOME}/projects"
project_directory="${projects_directory}/${project}"

if [[ ! -d "${project_directory}" ]]; then
  error 4 <<<"Project not found: ${project}"
fi

if systemctl --user --quiet is-active "virtdev-${project}" 2>/dev/null; then
  error 5 <<MESSAGE
Project virtual machine is running: ${project}
Stop it with: virtdev-stop ${project}
MESSAGE
fi

if port_in_use "${port}"; then
  error 6 <<<"Port ${port} is already in use on this host"
fi

# Check the port is not already registered to another project
if [[ -d "${projects_directory}" ]]; then
  while IFS= read -r port_file; do
    registered="$(< "${port_file}")"
    owner="$(basename "$(dirname "${port_file}")")"
    if [[ "${registered}" == "${port}" && "${owner}" != "${project}" ]]; then
      error 7 <<<"Port ${port} is already assigned to project '${owner}'"
    fi
  done < <(find "${projects_directory}" -maxdepth 2 -name port 2>/dev/null)
fi

old_port="$(< "${project_directory}/port")"
printf '%d\n' "${port}" > "${project_directory}/port"
printf "Port reassigned: %s %d -> %d\n" "${project}" "${old_port}" "${port}"
