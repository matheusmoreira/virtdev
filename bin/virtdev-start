#!/usr/bin/env bash
#
# virtdev-start <project> [port]
#
# Starts a project virtual machine as a transient systemd user service.
# The VM runs in the background, and systemd tracks the process.
#
# Lifecycle:
#
#     systemctl --user status virtdev-<project>     # status + recent logs
#     journalctl --user -u virtdev-<project>        # full logs
#     virtdev-stop <project>                        # clean ACPI shutdown
#
# Serial console access (when SSH is unavailable):
#
#     socat - UNIX-CONNECT:${VIRTDEV_HOME}/projects/<project>/console.sock
#

set -euo pipefail

error() {
  local -r code="${1}"
  cat >&2
  exit "${code}"
}

port_in_use() {
  [[ -n "$(ss -tlnH "sport = :${1}" 2>/dev/null)" ]]
}

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"
: "${VIRTDEV_VM_MEMORY:=4096}"
: "${VIRTDEV_VM_CPUS:=4}"
: "${OVMF_CODE:="/usr/share/edk2/x64/OVMF_CODE.4m.fd"}"

if [[ $# -lt 1 || $# -gt 2 ]]; then
  error 1 <<<'usage: virtdev-start <project> [port]'
fi

project="${1}"

if [[ ! "${project}" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  error 2 <<MESSAGE
Invalid project name: '${project}'
Allowed: a-z A-Z 0-9 _ -
MESSAGE
fi

# Acquire the exclusive virtdev lock. Held from here until after
# systemd confirms the transient unit is active, so any other virtdev
# script that arrives during the critical section waits for either
# (a) this start to complete and the unit to be visible via
# 'systemctl is-active', or (b) this start to fail cleanly. See
# virtdev-install for full rationale.
mkdir -p "${VIRTDEV_HOME}"
exec 9>>"${VIRTDEV_HOME}/lock"
if ! flock -n 9; then
  holder_pid="$(cat "${VIRTDEV_HOME}/lock" 2>/dev/null || true)"
  holder_cmdline=""
  if [[ -n "${holder_pid}" && -r "/proc/${holder_pid}/cmdline" ]]; then
    holder_cmdline="$(tr '\0' ' ' < "/proc/${holder_pid}/cmdline")"
  fi
  if [[ "${holder_cmdline}" == *virtdev-maintain* ]]; then
    error 12 <<MESSAGE
Base system maintenance is in progress (virtdev-maintain, PID ${holder_pid}).
Wait for it to finish or inspect its virtual machine:
    systemctl --user status virtdev-maintenance
MESSAGE
  fi
  error 12 <<MESSAGE
Another virtdev operation is in progress.
Lock file: ${VIRTDEV_HOME}/lock
Holder PID: ${holder_pid:-unknown}
MESSAGE
fi
: > "${VIRTDEV_HOME}/lock"
printf '%d\n' "$$" >&9

project_directory="${VIRTDEV_HOME}"/projects/"${project}"

if [[ ! -d "${project_directory}" ]]; then
  error 3 <<MESSAGE
Project not found: '${project_directory}'
Create project virtual machine first: virtdev-create '${project}'
MESSAGE
fi

for file in system.qcow2 home.qcow2 nvram; do
  if [[ ! -f "${project_directory}/${file}" ]]; then
    error 4 <<<"Project file missing: '${project_directory}/${file}'"
  fi
done

if [[ ! -f "${OVMF_CODE}" ]]; then
  error 5 <<<"Firmware not found: '${OVMF_CODE}'"
fi

# Detect base system changes since this project was created.
# After virtdev-maintain reseals the base, existing delta images
# are silently composed against the new base content by QEMU,
# which may produce filesystem corruption.
# Both version files must exist — otherwise there is no way to
# guarantee the delta is safe against the current base.
system_directory="${VIRTDEV_HOME}"/system
system_version_file="${system_directory}/version"
project_version_file="${project_directory}/version"

if [[ ! -f "${system_version_file}" ]]; then
  error 9 <<MESSAGE
Base system version file missing: '${system_version_file}'
The sealed base may be corrupted or from before versioning was added.
Reinstall the base system: virtdev-install + virtdev-seal
MESSAGE
fi

if [[ ! -f "${project_version_file}" ]]; then
  error 10 <<MESSAGE
Project version file missing: '${project_version_file}'
This project was created against a base that did not track versions,
or the file was removed. There is no way to verify the delta image
is safe against the current base content.
Transfer data and recreate this project on top of the current base:

    virtdev-destroy ${project} && virtdev-create ${project}
MESSAGE
fi

system_version="$(< "${system_version_file}")"
project_version="$(< "${project_version_file}")"

# Both version files must be a single non-negative integer. Anything
# else — empty, whitespace, non-numeric, negative — is either
# corruption or external tampering, and must not silently pass the
# equality check below where bash happens to compare strings. Future
# readers that touch this as arithmetic (e.g. to widen the check)
# would otherwise coerce bad input to 0 and match a zero on the
# other side.
if ! [[ "${system_version}" =~ ^[0-9]+$ ]]; then
  error 14 <<MESSAGE
Corrupted base version file: '${system_version_file}'
Contents: '${system_version}'
Repair manually: the file must contain a single non-negative integer.
MESSAGE
fi

if ! [[ "${project_version}" =~ ^[0-9]+$ ]]; then
  error 15 <<MESSAGE
Corrupted project version file: '${project_version_file}'
Contents: '${project_version}'
Repair manually: the file must contain a single non-negative integer.
MESSAGE
fi

if [[ "${system_version}" != "${project_version}" ]]; then
  error 11 <<MESSAGE
Base system has changed since this project was created.

	System version:  ${system_version}
	Project version: ${project_version}

Starting this project may cause filesystem corruption.
Transfer data and recreate it on top of the new base system:

    virtdev-destroy ${project} && virtdev-create ${project}
MESSAGE
fi

unit=virtdev-"${project}"

if systemctl --user --quiet is-active "${unit}" 2>/dev/null; then
  error 6 <<<"Project virtual machine is already running: ${project}"
fi

# Resolve SSH port
port_file="${project_directory}"/port

if [[ $# -eq 2 ]]; then
  # Explicit port from command line
  port="${2}"
  if [[ ! "${port}" =~ ^[0-9]+$ ]] || (( port < 1024 || port > 65535 )); then
    error 7 <<<"Invalid port: '${port}' (must be 1024-65535)"
  fi
  if port_in_use "${port}"; then
    error 8 <<<"Port ${port} is already in use on this host"
  fi
else
  # Auto-assign: lowest available port starting from 2222
  port=2222
  while port_in_use "${port}"; do
    (( port++ ))
    if (( port > 65535 )); then
      error 8 <<<"No available port found in range 2222-65535"
    fi
  done
fi

printf '%d\n' "${port}" > "${port_file}"

system_disk="${project_directory}"/system.qcow2
home_disk="${project_directory}"/home.qcow2
nvram="${project_directory}"/nvram
monitor_sock="${project_directory}"/monitor.sock
console_sock="${project_directory}"/console.sock

# Remove stale sockets from a previous unclean shutdown
rm -f "${monitor_sock}" "${console_sock}"

# Clear any residual failed state from a previous start attempt. Without
# --collect (see below), a unit that exited with error persists as
# 'failed' in systemd's state until explicitly reset, which would make
# the name-in-use collision below block retries.
systemctl --user reset-failed "${unit}" 2>/dev/null || true

printf "Starting project virtual machine %s on SSH port %d...\n" "${project}" "${port}"

# --collect intentionally omitted: it sets CollectMode=inactive-or-failed,
# which would let systemd garbage-collect a failed unit before anything
# can query ExecMainStatus or similar post-mortem properties. virtdev-stop
# reads those properties after the VM exits; leaving --collect off keeps
# the unit loaded until reset-failed or the next virtdev-start clears it.
systemd-run \
    --user \
    --unit="${unit}" \
    --description="virtdev project virtual machine: ${project}" \
    -- \
    qemu-system-x86_64 \
        -enable-kvm \
        -cpu host \
        -machine q35 \
        -m "${VIRTDEV_VM_MEMORY}" \
        -smp "${VIRTDEV_VM_CPUS}" \
        -drive if=pflash,format=raw,readonly=on,file="${OVMF_CODE}" \
        -drive if=pflash,format=raw,file="${nvram}" \
        -drive file="${system_disk}",if=virtio,format=qcow2 \
        -drive file="${home_disk}",if=virtio,format=qcow2 \
        -netdev user,id=net0,hostfwd=tcp:127.0.0.1:"${port}"-:22 \
        -device virtio-net-pci,netdev=net0 \
        -device virtio-rng-pci \
        -display none \
        -chardev socket,id=monitor,path="${monitor_sock}",server=on,wait=off \
        -monitor chardev:monitor \
        -chardev socket,id=serial,path="${console_sock}",server=on,wait=off \
        -serial chardev:serial

# Wait for systemd to confirm the transient unit is active before the
# lock is released (via script exit). systemd-run returns when the
# unit is queued; ActiveState transitions activating → active once
# systemd has started tracking it. Without this wait, another virtdev
# script could take the lock between systemd-run returning and
# systemd seeing the unit, and its 'is-active' check would falsely
# conclude the VM is not running.
#
# The three outcomes we care about are distinguished, so the user
# gets a targeted error message instead of a generic timeout:
#
#   - active:              normal, break out of the loop
#   - activating:          still booting, keep polling until deadline
#   - failed | inactive:   QEMU exited before activation completed
#                          (bad firmware path, bad qcow2 header,
#                          KVM initialisation failure, etc.) — fail
#                          fast with the captured exit status so the
#                          user is not told "unit did not become
#                          active" when in fact it entered and left
#                          in the same second
#   - other states:        treat as activating for timeout purposes
deadline=$(( SECONDS + 5 ))
while true; do
  state="$(systemctl --user show "${unit}" \
      --property=ActiveState --value 2>/dev/null || true)"
  case "${state}" in
    active)
      break
      ;;
    failed|inactive)
      exit_status="$(systemctl --user show "${unit}" \
          --property=ExecMainStatus --value 2>/dev/null || true)"
      exit_status="${exit_status:-unknown}"
      # Distinguish a port-bind race from a generic QEMU crash. The
      # pre-flight port_in_use check above is a TOCTOU: a non-virtdev
      # process can bind the chosen port between our check and qemu's
      # bind() call. From systemd's perspective this looks identical
      # to any other early QEMU exit, but the user-visible cause and
      # remediation are very different. Re-check the port now: if a
      # listener is on it, qemu's exit was almost certainly because
      # it could not bind. (TIME_WAIT sockets do not match -tln, so
      # this does not false-positive on QEMU's own brief lifetime.)
      if port_in_use "${port}"; then
        if [[ $# -eq 2 ]]; then
          error 8 <<MESSAGE
Port ${port} is bound by another process: ${unit} exit status ${exit_status}.
Between virtdev-start's pre-flight port check and qemu's bind() call,
a non-virtdev process took the port. The explicit port cannot be
retried until that process releases it.
Retry with a different port, or omit the port arg to auto-assign:
    virtdev-start ${project} <other-port>
    virtdev-start ${project}
MESSAGE
        else
          error 8 <<MESSAGE
Port ${port} is bound by another process: ${unit} exit status ${exit_status}.
Auto-assignment selected this port, but a non-virtdev process took
it between the port check and qemu's bind() call. Retry —
auto-assignment will pick the next free port:
    virtdev-start ${project}
MESSAGE
        fi
      fi
      error 13 <<MESSAGE
Unit exited before becoming active: ${unit}
ActiveState: ${state}
QEMU exit status: ${exit_status}
QEMU likely crashed at boot. Investigate:
    systemctl --user status ${unit}
    journalctl --user -u ${unit}
MESSAGE
      ;;
    *)
      if (( SECONDS >= deadline )); then
        error 13 <<MESSAGE
Unit did not become active within 5s: ${unit}
ActiveState: ${state:-unknown}
systemd-run reported success but systemctl does not see the unit active.
Investigate: systemctl --user status ${unit}
MESSAGE
      fi
      sleep 0.1
      ;;
  esac
done

printf 'VM started.\n'
printf 'SSH will be available after boot at: 127.0.0.1:%d\n' "${port}"
printf 'Shut down cleanly with: virtdev-stop %s\n' "${project}"
