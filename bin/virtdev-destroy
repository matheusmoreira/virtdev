#!/usr/bin/env bash
#
# virtdev-destroy <project>
#
# Permanently deletes a project virtual machine and all its disk images.
# The project must not be running.
#
# Requires typing the project name to confirm.
# This operation is irreversible.
#

set -euo pipefail

error() {
  local -r code="${1}"
  cat >&2
  exit "${code}"
}

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"

if [[ $# -ne 1 ]]; then
  error 1 <<<'usage: virtdev-destroy <project>'
fi

project="${1}"

if [[ ! "${project}" =~ ^[a-zA-Z0-9_-]{1,100}$ ]]; then
  error 2 <<MESSAGE
Invalid project name: '${project}'
Allowed: a-z A-Z 0-9 _ - (1 to 100 characters)
MESSAGE
fi

# Acquire the exclusive virtdev lock. See virtdev-install for the
# full rationale.
mkdir -p "${VIRTDEV_HOME}"
exec 9>>"${VIRTDEV_HOME}/lock"
if ! flock -n 9; then
  holder_pid="$(cat "${VIRTDEV_HOME}/lock" 2>/dev/null || true)"
  holder_cmdline=""
  if [[ -n "${holder_pid}" && -r "/proc/${holder_pid}/cmdline" ]]; then
    holder_cmdline="$(tr '\0' ' ' < "/proc/${holder_pid}/cmdline")"
  fi
  if [[ "${holder_cmdline}" == *virtdev-maintain* ]]; then
    error 6 <<MESSAGE
Base system maintenance is in progress (virtdev-maintain, PID ${holder_pid}).
Wait for it to finish or inspect its virtual machine:
    systemctl --user status virtdev-maintenance
MESSAGE
  fi
  error 6 <<MESSAGE
Another virtdev operation is in progress.
Lock file: ${VIRTDEV_HOME}/lock
Holder PID: ${holder_pid:-unknown}
MESSAGE
fi
: > "${VIRTDEV_HOME}/lock"
printf '%d\n' "$$" >&9

project_directory="${VIRTDEV_HOME}/projects/${project}"

if [[ ! -d "${project_directory}" ]]; then
  error 3 <<<"Project not found: ${project}"
fi

if systemctl --user --quiet is-active "virtdev-${project}" 2>/dev/null; then
  error 4 <<MESSAGE
Project virtual machine is running: ${project}
Stop it with: virtdev-stop ${project}
MESSAGE
fi

printf 'This will permanently delete:\n\n'
printf '\t%s\n' "${project_directory}"
find "${project_directory}" -type f \
  | sort \
  | while IFS= read -r f; do
      printf '\t\t%s\t%s\n' "$(du -sh "${f}" | cut -f1)" "$(basename "${f}")"
    done

backups_project_dir="${VIRTDEV_HOME}/backups/${project}"
if [[ -d "${backups_project_dir}" ]]; then
  snapshot_count=$(
    find "${backups_project_dir}" -mindepth 2 -maxdepth 2 -type d \
         -regextype posix-extended \
         -regex '.*/[0-9]{4}-[0-9]{2}-[0-9]{2}/[0-9]{2}-[0-9]{2}-[0-9]{2}' \
      2>/dev/null \
      | wc -l
  )
  if (( snapshot_count > 0 )); then
    printf '\nBackups preserved: %d snapshot(s) at %s\n' "${snapshot_count}" "${backups_project_dir}"
  fi
fi

printf '\nThis operation is irreversible.\n'
printf 'Type the project name to confirm: '
read -r confirmation

if [[ "${confirmation}" != "${project}" ]]; then
  error 5 <<<"Aborted."
fi

rm -rf "${project_directory}"
printf "Project destroyed: %s\n" "${project}"
