#!/usr/bin/env bash
#
# virtdev-destroy [--yes] <project>
#
# Permanently deletes a project virtual machine and all its disk images.
# The project must not be running.
#
# Requires typing the project name to confirm. The --yes flag skips
# the prompt; it exists primarily for virtdev-recreate, which drives
# destroy as one step in the destroy/rebuild chain. Other scripted
# callers (bulk cleanup loops, pipelines) can use it too.
#
# This operation is irreversible.
#

set -euo pipefail

virtdev_library_directory="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev"
declare -A virtdev_loaded_libraries=()
import() {
  local f
  for f in "$@"; do
    [[ -v virtdev_loaded_libraries[$f] ]] && continue
    virtdev_loaded_libraries[$f]=1
    # shellcheck disable=SC1090
    source -p "${virtdev_library_directory}" "${f}"
  done
}

import error validate lock arguments

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"

# shellcheck disable=SC2034  # spec/companions read via nameref
declare -A spec=([yes]=bool)
# shellcheck disable=SC2034
declare -A spec_short=([y]=yes)
# shellcheck disable=SC2034
declare -a spec_positionals=(project)
case "${1:-}" in
  --help|-h) arguments_usage spec ; exit 0 ;;
esac
declare -A flags=()
declare -a positional=()
arguments_parse spec flags positional "$@"
set -- "${positional[@]}"

if [[ $# -ne 1 ]]; then
  error 64 <<<"$(arguments_usage spec)"
fi

project="${1}"

validate_project_name "${project}"

lock_acquire

project_directory="${VIRTDEV_HOME}/projects/${project}"

if [[ ! -d "${project_directory}" ]]; then
  error 3 <<<"Project not found: ${project}"
fi

if systemctl --user --quiet is-active "virtdev-${project}" 2>/dev/null; then
  error 4 <<MESSAGE
Project virtual machine is running: ${project}
Stop it with: virtdev-stop ${project}
MESSAGE
fi

printf 'This will permanently delete:\n\n'
printf '\t%s\n' "${project_directory}"
find "${project_directory}" -type f \
  | sort \
  | while IFS= read -r f; do
      printf '\t\t%s\t%s\n' "$(du -sh "${f}" | cut -f1)" "$(basename "${f}")"
    done

backups_project_dir="${VIRTDEV_HOME}/backups/${project}"
if [[ -d "${backups_project_dir}" ]]; then
  snapshot_count=$(
    find "${backups_project_dir}" -mindepth 2 -maxdepth 2 -type d \
         -regextype posix-extended \
         -regex '.*/[0-9]{4}-[0-9]{2}-[0-9]{2}/[0-9]{2}-[0-9]{2}-[0-9]{2}' \
      2>/dev/null \
      | wc -l
  )
  if (( snapshot_count > 0 )); then
    printf '\nBackups preserved: %d snapshot(s) at %s\n' "${snapshot_count}" "${backups_project_dir}"
  fi
fi

printf '\nThis operation is irreversible.\n'

if (( ! flags[yes] )); then
  printf 'Type the project name to confirm: '
  read -r confirmation
  if [[ "${confirmation}" != "${project}" ]]; then
    error 5 <<<"Aborted."
  fi
fi

rm -rf "${project_directory}"
printf "Project destroyed: %s\n" "${project}"
