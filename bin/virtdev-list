#!/usr/bin/env bash
#
# virtdev-list
#
# Lists all project virtual machines with their SSH port and status.
#
# Output columns:
#
#   PROJECT   Name of the project virtual machine
#   PORT      Host-side SSH forwarding port
#   STATUS    running | stopped
#

set -euo pipefail

virtdev_library_directory="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev"
declare -A virtdev_loaded_libraries=()
import() {
  local f
  for f in "$@"; do
    [[ -v virtdev_loaded_libraries[$f] ]] && continue
    virtdev_loaded_libraries[$f]=1
    # shellcheck disable=SC1090
    source -p "${virtdev_library_directory}" "${f}"
  done
}

import error arguments

# shellcheck disable=SC2034  # spec read via nameref
declare -A spec=()
case "${1:-}" in
  --help|-h) arguments_usage spec ; exit 0 ;;
esac
# shellcheck disable=SC2034
declare -A flags=()
declare -a positional=()
arguments_parse spec flags positional "$@"
set -- "${positional[@]}"

if [[ $# -ne 0 ]]; then
  error 64 <<<"$(arguments_usage spec)"
fi

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"

projects_directory="${VIRTDEV_HOME}/projects"

if [[ ! -d "${projects_directory}" ]]; then
  printf 'No projects found.\n'
  exit 0
fi

mapfile -t projects < <(
  find "${projects_directory}" -maxdepth 1 -mindepth 1 -type d -printf '%f\n' \
    | sort
)

if [[ ${#projects[@]} -eq 0 ]]; then
  printf 'No projects found.\n'
  exit 0
fi

printf '%-50s %-5s %s\n' 'PROJECT' 'PORT' 'STATUS'
printf '%-50s %-5s %s\n' '-------' '----' '------'

for project in "${projects[@]}"; do
  [[ "${project}" =~ ^[a-zA-Z0-9_-]{1,100}$ ]] || continue
  project_directory="${projects_directory}"/"${project}"
  port_file="${project_directory}"/port

  if systemctl --user --quiet is-active "virtdev-${project}" 2>/dev/null; then
    status='running'
    if [[ -f "${port_file}" ]]; then
      port="$(< "${port_file}")"
    else
      port='?'
    fi
  else
    status='stopped'
    port='-'
  fi

  printf '%-50s %-5s %s\n' "${project}" "${port}" "${status}"
done
