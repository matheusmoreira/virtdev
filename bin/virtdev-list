#!/usr/bin/env bash
#
# virtdev-list
#
# Lists all project virtual machines with their SSH port and status.
#
# Output columns:
#
#   PROJECT   Name of the project virtual machine
#   PORT      Host-side SSH forwarding port
#   STATUS    running | stopped
#   GENERATION  Base generation the project was created against,
#               or 'detached' for standalone projects
#

set -euo pipefail

# shellcheck disable=SC1090,SC1091
source "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev/import"

import error arguments project terminal

# shellcheck disable=SC2034  # spec/companions read via nameref
declare -A spec=()
# shellcheck disable=SC2034
declare -A flags=()
declare -a positional=()
arguments_parse spec flags positional "$@"
set -- "${positional[@]}"

if [[ $# -ne 0 ]]; then
  error 64 <<<"$(arguments_usage spec)"
fi

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"

mapfile -t projects < <(project_list)

if [[ ${#projects[@]} -eq 0 ]]; then
  printf >&2 'No projects found.\n'
  exit 0
fi

system_generation_file="${VIRTDEV_HOME}/system/generation"
base_generation='-'
if [[ -f "${system_generation_file}" ]]; then
  base_generation="$(< "${system_generation_file}")"
fi

printf '%-50s %-5s %-8s %s\n' 'PROJECT' 'PORT' 'STATUS' 'GENERATION'
printf '%-50s %-5s %-8s %s\n' '-------' '----' '------' '----------'

declare -A running_state=()
project_load_running_state running_state "${projects[@]}"

for project in "${projects[@]}"; do
  project_directory="${VIRTDEV_HOME}/projects/${project}"
  port_file="${project_directory}/port"
  generation_file="${project_directory}/generation"

  if [[ "${running_state[${project}]}" == "1" ]]; then
    status='running'
    status_color='fg=green'
    if [[ -f "${port_file}" ]]; then
      port="$(< "${port_file}")"
    else
      port='?'
    fi
  else
    status='stopped'
    status_color='fg=red'
    port='-'
  fi

  generation='-'
  generation_color=''
  if [[ -f "${generation_file}" ]]; then
    generation="$(< "${generation_file}")"
    if [[ "${generation}" == "detached" ]]; then
      generation_color='fg=yellow'
    elif [[ "${base_generation}" != '-' && "${generation}" != "${base_generation}" ]]; then
      generation_color='fg=red'
    fi
  fi

  # printf counts escape bytes as width, so colored fields
  # use manual padding: print the colored text, then pad to
  # the column width with spaces.
  colored_status="$(terminal_write "${status_color}" "${status}" reset)"
  if [[ -n "${generation_color}" ]]; then
    colored_generation="$(terminal_write "${generation_color}" "${generation}" reset)"
  else
    colored_generation="${generation}"
  fi

  printf '%-50s %-5s %s%-*s %s\n' \
    "${project}" "${port}" \
    "${colored_status}" $(( 8 - ${#status} )) "" \
    "${colored_generation}"
done

if [[ "${base_generation}" != '-' ]]; then
  printf >&2 '\nBase generation: %s\n' "${base_generation}"
fi