#!/usr/bin/env bash
#
# virtdev-detach [--in-place] [--yes] <project>
#
# Converts a project's qcow2 delta images into standalone images by
# absorbing the sealed base system. This removes the backing file
# dependency, making the project immune to maintenance cycles and
# generation mismatches. Trade-off: larger disk footprint, independent
# updates required.
#
# Two conversion modes:
#
#   Default (convert-then-swap):
#       Creates new standalone images alongside the originals, verifies
#       them, then renames into place. Originals are untouched until the
#       swap. Temporarily needs extra disk space (roughly one copy of
#       the base per disk).
#
#   --in-place (rebase):
#       Modifies images in place via qemu-img rebase. Less disk space
#       and write volume. No rollback on interruption — if the rebase
#       is interrupted, the image is in an undefined state.
#
# Both modes verify the resulting images with qemu-img check.
#
# The project must be stopped. A detached project:
#
#   - Boots without a generation check (virtdev-start skips it)
#   - Is skipped by virtdev-upgrade (independent of the base)
#   - Shows 'detached' in virtdev-list's GENERATION column
#   - Returns to coupled state if recreated (virtdev-recreate)
#
# Lock model: acquires the virtdev lock before mutation. The conversion
# reads sealed base images and rewrites project qcow2 files.
#
# Exit codes:
#
#   0   success
#   3   project not found
#   4   virtual machine is running
#   5   already detached
#   6   disk has no backing file
#   8   user aborted at confirmation prompt
#   10  convert/rebase failed for system disk
#   11  convert/rebase failed for home disk
#   12  verification failed
#
# Configuration via environment variables:
#
#   VIRTDEV_HOME    Default: ${XDG_DATA_HOME:-~/.local/share}/virtdev
#

set -euo pipefail

# shellcheck disable=SC1090,SC1091
source "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev/import"

import error validate lock arguments project confirm terminal

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"

# shellcheck disable=SC2034  # spec/companions read via nameref
declare -A spec=(
  [in-place]=bool
  [yes]=bool
)
# shellcheck disable=SC2034
declare -A spec_short=([y]=yes)
# shellcheck disable=SC2034
declare -a spec_positionals=(project)
declare -A flags=()
declare -a positional=()
arguments_parse spec flags positional "$@"
set -- "${positional[@]}"

if [[ $# -ne 1 ]]; then
  error 64 <<<"$(arguments_usage spec)"
fi

project="${1}"

validate_project_name "${project}"

project_directory="${VIRTDEV_HOME}/projects/${project}"

if [[ ! -d "${project_directory}" ]]; then
  error 3 <<<"Project not found: ${project}"
fi

if project_is_running "${project}"; then
  error 4 <<MESSAGE
Virtual machine is running: ${project}
Stop it first: virtdev-stop ${project}
MESSAGE
fi

if project_is_detached "${project}"; then
  error 5 <<<"Already detached: ${project}"
fi

system_disk="${project_directory}/system.qcow2"
home_disk="${project_directory}/home.qcow2"
generation_file="${project_directory}/generation"

# Verify both disks have backing files.
has_backing() {
  qemu-img info --output=json "${1}" \
    | grep -q '"backing-filename"'
}

if ! has_backing "${system_disk}"; then
  error 6 <<<"System disk has no backing file: ${system_disk}"
fi

if ! has_backing "${home_disk}"; then
  error 6 <<<"Home disk has no backing file: ${home_disk}"
fi

# Read current generation for the summary display.
current_generation='-'
if [[ -f "${generation_file}" ]]; then
  current_generation="$(< "${generation_file}")"
fi

# Print summary.
{
  printf '\nDetaching project: %s\n' "${project}"
  printf '  System disk: %s\n' "${system_disk}"
  printf '  Home disk:   %s\n' "${home_disk}"
  printf '  Generation:  %s\n' "${current_generation}"
  if (( flags[in-place] )); then
    printf '  Mode:        in-place (no rollback on interruption)\n'
  else
    printf '  Mode:        convert (use --in-place to rebase in place)\n'
  fi
  printf '\n  No backup will be taken. Consider running virtdev-backup first.\n\n'
} >&2

if (( ! flags[yes] )); then
  if ! confirm_proceed; then
    error 8 <<<"Aborted."
  fi
fi

lock_acquire

system_bak="${system_disk}.bak"
home_bak="${home_disk}.bak"

# Auto-recover from an interrupted convert-then-swap. The .bak files
# are the originals, renamed aside during the swap. Their presence
# means the swap was interrupted before cleanup. Restore them so the
# project is back in its pre-detach state and the user can retry.
if [[ -f "${system_bak}" || -f "${home_bak}" ]]; then
  printf >&2 '%s\n' "$(terminal_write fg=yellow 'Detected interrupted detach swap. Recovering...' reset)"
  [[ -f "${system_bak}" ]] && mv -f "${system_bak}" "${system_disk}"
  [[ -f "${home_bak}" ]]   && mv -f "${home_bak}" "${home_disk}"
  rm -f "${system_disk}.detach" "${home_disk}.detach"
  printf >&2 '%s\n\n' "$(terminal_write fg=green 'Recovery complete. Project restored to pre-detach state.' reset)"
fi

if (( flags[in-place] )); then
  # ── In-place mode (rebase) ──────────────────────────────────────

  printf >&2 'Rebasing system disk...\n'
  if ! qemu-img rebase -b "" -f qcow2 "${system_disk}"; then
    error 10 <<MESSAGE
Rebase failed for system disk: ${system_disk}
The image may be in an undefined state. Restore from backup.
MESSAGE
  fi

  printf >&2 'Rebasing home disk...\n'
  if ! qemu-img rebase -b "" -f qcow2 "${home_disk}"; then
    error 11 <<MESSAGE
Rebase failed for home disk: ${home_disk}
The system disk was already rebased. Both images may be in an
undefined state. Restore from backup.
MESSAGE
  fi

  printf >&2 'Verifying...\n'
  verify_failed=0
  if ! qemu-img check -q "${system_disk}"; then
    printf >&2 '%s\n' "$(terminal_write fg=yellow 'Warning: system disk verification failed.' reset)"
    verify_failed=1
  fi
  if ! qemu-img check -q "${home_disk}"; then
    printf >&2 '%s\n' "$(terminal_write fg=yellow 'Warning: home disk verification failed.' reset)"
    verify_failed=1
  fi

  printf 'detached\n' > "${generation_file}"
  chmod 644 "${generation_file}"

  if (( verify_failed )); then
    printf >&2 '\n%s\n' "$(terminal_write fg=yellow "Project detached: ${project} (with verification warnings)" reset)"
    printf >&2 'Check the images or restore from backup.\n'
    exit 12
  fi

else
  # ── Default mode (convert-then-swap) ────────────────────────────

  system_detach="${system_disk}.detach"
  home_detach="${home_disk}.detach"

  cleanup_temps() {
    rm -f "${system_detach}" "${home_detach}"
  }

  printf >&2 'Converting system disk...\n'
  if ! qemu-img convert -O qcow2 "${system_disk}" "${system_detach}"; then
    cleanup_temps
    error 10 <<MESSAGE
Convert failed for system disk: ${system_disk}
Project is unchanged. Check disk space and retry.
MESSAGE
  fi

  printf >&2 'Converting home disk...\n'
  if ! qemu-img convert -O qcow2 "${home_disk}" "${home_detach}"; then
    cleanup_temps
    error 11 <<MESSAGE
Convert failed for home disk: ${home_disk}
Project is unchanged. Check disk space and retry.
MESSAGE
  fi

  printf >&2 'Verifying...\n'
  if ! qemu-img check -q "${system_detach}" || ! qemu-img check -q "${home_detach}"; then
    cleanup_temps
    error 12 <<MESSAGE
Verification failed for converted images.
Project is unchanged. The converted images have been removed.
MESSAGE
  fi

  # Swap: rename originals aside, move converted images into place,
  # write the generation marker, then remove the originals. Signals
  # are trapped for the critical section — a SIGKILL or power loss
  # would leave .bak files which the auto-recovery above handles on
  # the next invocation.
  trap '' INT TERM HUP QUIT
  printf >&2 'Swapping...\n'
  mv "${system_disk}" "${system_bak}"
  mv "${system_detach}" "${system_disk}"
  mv "${home_disk}" "${home_bak}"
  mv "${home_detach}" "${home_disk}"
  printf 'detached\n' > "${generation_file}"
  chmod 644 "${generation_file}"
  rm -f "${system_bak}" "${home_bak}"
  trap - INT TERM HUP QUIT
fi

printf 'Done.\n\n' >&2
printf >&2 '%s\n' "$(terminal_write fg=green "Project detached: ${project}" reset)"
