#!/usr/bin/env bash
#
# virtdev-backup [--verbose] <project>
# virtdev-backup --list <project>
#
# Snapshots user-curated guest-side paths from a running project
# virtual machine into a timestamped host-side directory.
# Snapshots land at:
#
#   ${VIRTDEV_HOME}/backups/<project>/<YYYY-MM-DD>/<HH-MM-SS>/
#
# Each snapshot contains:
#
#   project            the source project name; virtdev-restore uses
#                      this to refuse cross-project restoration
#   manifest        copy of projects/<project>/manifest at backup time
#   generation         integer from ${VIRTDEV_HOME}/system/generation (or empty)
#   tree/              user-content subtree, rsync-preserved
#
# The manifest is user-curated and required. Lookup order:
#
#   1. ${VIRTDEV_HOME}/projects/<project>/manifest
#   2. ${XDG_CONFIG_HOME:-~/.config}/virtdev/projects/<project>/manifest
#
# First existing file wins. Put your stable manifest in the config
# location (dotfile-friendly, survives virtdev-nuke) and use the
# project-local location for one-off experiments that should be
# discarded with the VM.
#
# Format: one path per line; blank lines and lines starting with
# '#' are ignored. All paths are relative to the guest's /home/dev/
# — rsync's --files-from cannot reach outside the source root, and
# absolute paths in the manifest are rejected at backup time
# (rsync would silently strip the leading slash and look up the
# remainder under /home/dev/, producing missing files). Trailing
# slash follows rsync convention.
#
# The loaded manifest path is echoed to stderr on each run.
#
# Flags:
#
#   --verbose    Show rsync per-file progress.
#   --list       Print snapshots for the project. Does not create
#                a snapshot; does not require the VM to be running.
#
# The project's virtual machine must be running (SSH over the
# host-forwarded port). Concurrent same-project backups at the same
# second are prevented by mkdir EEXIST on the partial directory.
#
# Requires rsync on both host and guest:
#
#     pacman -S rsync
#
# Configuration via environment variables:
#
#   VIRTDEV_HOME       Default: ${XDG_DATA_HOME:-~/.local/share}/virtdev
#   VIRTDEV_SSH_KEY    Default: ${VIRTDEV_HOME}/ssh/id
#   XDG_CONFIG_HOME    Default: ~/.config
#

set -euo pipefail

# shellcheck disable=SC1090,SC1091
source "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev/import"

import error validate arguments ssh snapshot manifest terminal

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"
: "${VIRTDEV_SSH_KEY:="${VIRTDEV_HOME}/ssh/id"}"
: "${XDG_CONFIG_HOME:="${HOME}/.config"}"

umask 077

# shellcheck disable=SC2034  # spec/companions read via nameref
declare -A spec=([verbose]=bool [list]=bool)
# shellcheck disable=SC2034
declare -A spec_short=([v]=verbose [l]=list)
# shellcheck disable=SC2034
declare -a spec_positionals=(project)
declare -A flags=()
declare -a positional=()
arguments_parse spec flags positional "$@"
set -- "${positional[@]}"

if [[ $# -ne 1 ]]; then
  if (( flags[list] )); then
    error 64 <<<'usage: virtdev-backup -l|--list <project>'
  else
    error 64 <<<'usage: virtdev-backup [-v|--verbose] <project>'
  fi
fi

project="${1}"

validate_project_name "${project}"

project_directory="${VIRTDEV_HOME}/projects/${project}"

if [[ ! -d "${project_directory}" ]]; then
  error 3 <<<"Project not found: ${project}"
fi

# List mode stops here; it lists past snapshots regardless of VM state.
if (( flags[list] )); then
  backups_project_dir="$(snapshot_directory "${project}")"
  mapfile -t day_dirs < <(snapshot_list_days "${project}")

  if (( ${#day_dirs[@]} == 0 )); then
    printf >&2 'No snapshots.\n'
    exit 0
  fi

  printf '%-12s  %-10s %-10s %-8s %s\n' 'DATE' 'TIME' 'AGE' 'SIZE' 'GENERATION'
  printf '%-12s  %-10s %-10s %-8s %s\n' '----' '----' '---' '----' '----------'

  now=$(date -u +%s)

  humanize_age() {
    local -r seconds="${1}"
    if (( seconds < 60 )); then
      printf '%ds ago' "${seconds}"
    elif (( seconds < 3600 )); then
      printf '%dm ago' "$((seconds / 60))"
    elif (( seconds < 86400 )); then
      printf '%dh ago' "$((seconds / 3600))"
    else
      printf '%dd ago' "$((seconds / 86400))"
    fi
  }

  for d in "${day_dirs[@]}"; do
    mapfile -t time_dirs < <(snapshot_list_times "${project}" "${d}")
    for t in "${time_dirs[@]}"; do
      snapshot="${backups_project_dir}/${d}/${t}"
      size="$(du -sh "${snapshot}" 2>/dev/null | cut -f1)"
      # Display the snapshot's recorded base generation. Empty/absent
      # = legitimate 'unknown at backup time' shows as '-'. Any
      # non-empty value that does not match the integer convention
      # is shown as '<corrupt>' rather than the raw string, so
      # broken metadata is visible without polluting the column.
      # --list is read-only and tolerant; the writer below catches
      # the corrupt-input case at backup time and refuses then.
      generation='-'
      if [[ -s "${snapshot}/generation" ]]; then
        generation="$(< "${snapshot}/generation")"
        if ! [[ "${generation}" =~ ^[0-9]+$ ]]; then
          generation='<corrupt>'
        fi
      fi
      time_colons="${t//-/:}"
      snap_epoch=$(date -u -d "${d} ${time_colons} UTC" +%s 2>/dev/null || echo 0)
      age_seconds=$(( now - snap_epoch ))
      (( age_seconds < 0 )) && age_seconds=0
      age="$(humanize_age "${age_seconds}")"
      printf '%-12s  %-10s %-10s %-8s %s\n' "${d}" "${t}" "${age}" "${size}" "${generation}"
    done
  done
  exit 0
fi

# From here on: create mode preconditions (4 and up).

if ! systemctl --user --quiet is-active "virtdev-${project}" 2>/dev/null; then
  error 4 <<MESSAGE
Virtual machine is not running: ${project}
Start it with: virtdev-start ${project}
MESSAGE
fi

port_file="${project_directory}/port"
if [[ ! -f "${port_file}" ]]; then
  error 13 <<MESSAGE
Project has no port assigned: ${project}
Start the virtual machine first: virtdev-start ${project}
MESSAGE
fi
port="$(< "${port_file}")"

ssh_key_validate "${VIRTDEV_SSH_KEY}"

if ! command -v rsync &>/dev/null; then
  error 6 <<MESSAGE
rsync not found
Install it with: pacman -S rsync
MESSAGE
fi

if ! manifest_path="$(manifest_resolve "${project}")"; then
  error 8 <<MESSAGE
Backup manifest not found. Checked (in order):
	${project_directory}/manifest
	${XDG_CONFIG_HOME}/virtdev/projects/${project}/manifest
Create either; one path per line, relative to /home/dev/.
Blank lines and '#' comments are ignored.
MESSAGE
fi

if ! manifest_has_entries "${manifest_path}"; then
  error 9 <<MESSAGE
Backup manifest has no paths: ${manifest_path}
All lines are blank or comments. Add at least one path.
MESSAGE
fi

# Reject absolute paths. rsync's --files-from semantics strip the
# leading '/' and resolve every entry relative to the source dir
# (here, /home/dev/), so '/etc/foo.conf' would silently look up
# /home/dev/etc/foo.conf and (with --ignore-missing-args) be
# omitted from the snapshot. Surface this as a hard error rather
# than allow a silently-incomplete backup. Match leading-slash
# entries even with surrounding whitespace.
abs_lines="$(grep -nE '^\s*/' "${manifest_path}" || true)"
if [[ -n "${abs_lines}" ]]; then
  error 15 <<MESSAGE
Backup manifest contains absolute paths: ${manifest_path}
${abs_lines}
Manifest entries must be relative to the guest's /home/dev/.
MESSAGE
fi

# Reject malformed path-shape entries: leading whitespace, trailing
# whitespace, embedded control characters. rsync's --files-from
# treats each line literally, so 'notes.md  ' (trailing spaces, common
# on copy-paste) becomes a path with two trailing spaces — which
# does not exist and gets silently skipped under
# --ignore-missing-args. Same for ' .bashrc' (leading space, easy
# to introduce when reformatting). Embedded tabs and CRs (Windows
# line endings) are similarly suspicious. Validate up front so the
# user fixes the manifest, not the snapshot.
bad_shape="$(awk '
  /^[[:space:]]*$/ { next }
  /^[[:space:]]*#/ { next }
  /^[[:space:]]/  { printf("%d: leading whitespace: %s\n", NR, $0); next }
  /[[:space:]]$/  { printf("%d: trailing whitespace: %s\n", NR, $0); next }
  /[[:cntrl:]]/   { printf("%d: control character: %s\n", NR, $0); next }
' "${manifest_path}")"
if [[ -n "${bad_shape}" ]]; then
  error 16 <<MESSAGE
Backup manifest has malformed path entries: ${manifest_path}
${bad_shape}
Each path must start at column 0, end with a non-whitespace
character, and contain no tabs or control characters.
MESSAGE
fi

printf >&2 'manifest: %s\n' "${manifest_path}"

day="$(date -u +%Y-%m-%d)"
time="$(date -u +%H-%M-%S)"

backups_project_dir="${VIRTDEV_HOME}/backups/${project}"
day_dir="${backups_project_dir}/${day}"
partial="${day_dir}/${time}.partial"
final="${day_dir}/${time}"

# shellcheck disable=SC2174  # umask 077 above ensures intermediates get 0700 too
mkdir -p -m 0700 "${day_dir}"

if ! mkdir -m 0700 "${partial}" 2>/dev/null; then
  error 10 <<MESSAGE
Partial snapshot already exists: ${partial}
Either another backup is in progress, or a previous backup was
killed (SIGKILL or similar) without its EXIT trap firing.
Remove it if stale: rm -rf "${partial}"
MESSAGE
fi

backup_succeeded=0
rsync_log=
cleanup_partial() {
  (( backup_succeeded )) || rm -rf "${partial}"
  [[ -n "${rsync_log}" ]] && rm -f "${rsync_log}"
}
trap cleanup_partial EXIT

cp "${manifest_path}" "${partial}/manifest"

# Record the source project. virtdev-restore reads this and refuses
# to proceed if its <project> argument disagrees, which catches the
# common 'snapshot directory copied between projects, restore picks
# the wrong one' failure mode. Without this marker the snapshot is
# indistinguishable from any other and a cross-project restore would
# silently overwrite the target project's home with the source's.
printf '%s\n' "${project}" > "${partial}/project"

# Read and validate the base generation. Refusing to write an unreadable
# value into the snapshot keeps the validate-everywhere convention
# (see commit 4b82a64) consistent across the new producer site.
# Empty / missing base generation is a legitimate "pre-generation-tracking
# seal" state and is preserved as an empty file in the snapshot, matching
# how virtdev-restore tolerates and displays it.
generation_file="${VIRTDEV_HOME}/system/generation"
if [[ -f "${generation_file}" ]]; then
  base_generation="$(< "${generation_file}")"
  if ! [[ "${base_generation}" =~ ^[0-9]+$ ]]; then
    error 12 <<MESSAGE
Corrupted base generation file: '${generation_file}'
Contents: '${base_generation}'
Repair manually: the file must contain a single non-negative integer.
Refusing to seal a corrupt audit trail into the snapshot.
MESSAGE
  fi
  printf '%s\n' "${base_generation}" > "${partial}/generation"
else
  : > "${partial}/generation"
fi

mkdir -m 0700 "${partial}/tree"

# Build the SSH command for rsync's -e. printf %q survives rsync's
# internal shell reparse even if VIRTDEV_SSH_KEY or port contain
# unusual characters. Matches bin/virtdev-transfer.
printf -v ssh_command \
    'ssh -i %q -p %q -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR' \
    "${VIRTDEV_SSH_KEY}" "${port}"

rsync_opts=(-a --no-D --ignore-missing-args --stats)
(( flags[verbose] )) && rsync_opts+=(--info=progress2)

rsync_log="$(mktemp)"

printf >&2 'Backing up %s to %s...\n' "${project}" "${final#"${VIRTDEV_HOME}"/}"

# Force LC_ALL=C so rsync's --stats output is in English. The
# zero-file guard and the partial-transfer count both parse the
# 'Number of regular files transferred:' line; under a non-English
# locale rsync would emit a translated label, the awk match would
# fail silently, files_transferred would default to 0, and a
# successful backup would be wrongly rejected by error 11.
if ! LC_ALL=C rsync "${rsync_opts[@]}" \
    --files-from=<(grep -Ev '^\s*(#|$)' "${partial}/manifest") \
    -e "${ssh_command}" \
    "dev@127.0.0.1:/home/dev/" \
    "${partial}/tree/" \
    | tee "${rsync_log}"; then
  # PIPESTATUS[0] is rsync's exit code; pipefail propagates it as the
  # pipeline's non-zero status. Distinguish the partial-transfer
  # codes (23, 24) from a transport failure (255) and from any other
  # rsync-level error so the user sees a targeted hint, mirroring
  # virtdev-restore. The trap removes the partial snapshot in all
  # paths, so host-side state stays consistent across the dispatch.
  rsync_exit="${PIPESTATUS[0]}"
  case "${rsync_exit}" in
    23|24)
      partial_count="$(awk -F: '/^Number of regular files transferred:/ {
        gsub(/[ ,]/, "", $2); print $2
      }' "${rsync_log}")"
      error 7 <<MESSAGE
rsync transfer of ${project} completed with errors (exit ${rsync_exit}).
${partial_count:-?} files were transferred; the rest were skipped or failed.
The partial snapshot has been removed.
See the per-file output above for which entries failed; verify the
manifest against the guest with: virtdev-ssh ${project} ls -la
MESSAGE
      ;;
    255)
      error 17 <<MESSAGE
rsync transfer failed during backup of ${project} (exit 255: transport).
The SSH connection to the guest could not be established or was lost.
The partial snapshot has been removed.
Verify the VM is reachable, then retry:

    virtdev-ssh ${project} true
    virtdev-backup ${project}
MESSAGE
      ;;
    *)
      error 18 <<MESSAGE
rsync transfer failed during backup of ${project} (exit ${rsync_exit}).
The transfer aborted before completion. See the per-file output
above for the cause. The partial snapshot has been removed.
MESSAGE
      ;;
  esac
fi

# Refuse a snapshot that received zero files. The manifest may
# reference paths that all happen to be absent on the guest (typo,
# wrong project, recently deleted) — with --ignore-missing-args,
# rsync silently skips them and exits 0. Without this check the
# resulting snapshot would be promoted to final/ and the user would
# only discover the empty payload at restore time, possibly after a
# destroy-recreate cycle had already removed the source data.
# Mirrors the equivalent guard in virtdev-restore.
files_transferred="$(awk -F: '/^Number of regular files transferred:/ {
  gsub(/[ ,]/, "", $2); print $2
}' "${rsync_log}")"
files_transferred="${files_transferred:-0}"

if (( files_transferred == 0 )); then
  error 11 <<MESSAGE
Zero files transferred during backup of ${project}.
Every manifest entry was skipped — most commonly because the
referenced paths do not exist on the guest. The partial snapshot
has been removed.
Verify the manifest against the guest: virtdev-ssh ${project} ls -la
MESSAGE
fi

mv "${partial}" "${final}"
backup_succeeded=1

printf >&2 '%s\n' "$(terminal_write fg=green "Backed up ${files_transferred} files." reset)"
printf '%s\n' "${final}"