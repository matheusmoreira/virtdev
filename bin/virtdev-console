#!/usr/bin/env bash
#
# virtdev-console <project>
#
# Attaches to the serial console of a running project virtual machine.
# Useful for debugging boot failures or networking issues
# before SSH becomes available.
#
# Detach with Ctrl-].
#
# Requires socat.
#
#     pacman -S socat
#

set -euo pipefail

virtdev_library_directory="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev"
declare -A virtdev_loaded_libraries=()
import() {
  local f
  for f in "$@"; do
    [[ -v virtdev_loaded_libraries[$f] ]] && continue
    virtdev_loaded_libraries[$f]=1
    # shellcheck disable=SC1090
    source -p "${virtdev_library_directory}" "${f}"
  done
}

import error validate

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"

if [[ $# -ne 1 ]]; then
  error 1 <<<'usage: virtdev-console <project>'
fi

project="${1}"

validate_project_name "${project}"

project_directory="${VIRTDEV_HOME}/projects/${project}"

if [[ ! -d "${project_directory}" ]]; then
  error 3 <<<"Project virtual machine not found: ${project}"
fi

console_sock="${project_directory}/console.sock"
if [[ ! -S "${console_sock}" ]]; then
  error 4 <<MESSAGE
Project virtual machine is not running: ${project}
Start it with: virtdev-start ${project}
MESSAGE
fi

if ! command -v socat &>/dev/null; then
  error 5 <<<'socat not found, install with: pacman -S socat'
fi

printf 'Attaching to serial console of %s.\nDetach with Ctrl-].\n\n' "${project}"
exec socat - UNIX-CONNECT:"${console_sock}"
