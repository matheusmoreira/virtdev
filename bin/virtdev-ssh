#!/usr/bin/env bash
#
# virtdev-ssh <project> [ssh-args...]
#
# Connects into a running project virtual machine
# via SSH and as the dev user.
#
# Additional arguments are passed through to ssh verbatim,
# allowing remote command execution:
#
#     virtdev-ssh myproject
#     virtdev-ssh myproject -- ls -la
#     virtdev-ssh myproject -L 3000:localhost:3000
#
# The SSH key is read from VIRTDEV_SSH_KEY,
# defaulting to ${VIRTDEV_HOME}/ssh/id.
#
#     export VIRTDEV_SSH_KEY=~/.ssh/virtdev_id
#

set -euo pipefail

virtdev_library_directory="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev"
declare -A virtdev_loaded_libraries=()
import() {
  local f
  for f in "$@"; do
    [[ -v virtdev_loaded_libraries[$f] ]] && continue
    virtdev_loaded_libraries[$f]=1
    # shellcheck disable=SC1090
    source -p "${virtdev_library_directory}" "${f}"
  done
}

import error

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"
: "${VIRTDEV_SSH_KEY:="${VIRTDEV_HOME}/ssh/id"}"

if [[ $# -lt 1 ]]; then
  error 1 <<<'usage: virtdev-ssh <project> [ssh-args...]'
fi

project="${1}"
shift

if [[ ! "${project}" =~ ^[a-zA-Z0-9_-]{1,100}$ ]]; then
  error 2 <<MESSAGE
Invalid project name: '${project}'
Allowed: a-z A-Z 0-9 _ - (1 to 100 characters)
MESSAGE
fi

project_directory="${VIRTDEV_HOME}/projects/${project}"

if [[ ! -d "${project_directory}" ]]; then
  error 3 <<<"Project not found: ${project}"
fi

port_file="${project_directory}/port"
if [[ ! -f "${port_file}" ]]; then
  error 4 <<MESSAGE
Project has no port assigned: ${project}
Start the virtual machine first: virtdev-start ${project}
MESSAGE
fi

port="$(< "${port_file}")"

if ! systemctl --user --quiet is-active "virtdev-${project}" 2>/dev/null; then
  error 5 <<MESSAGE
Virtual machine is not running: ${project}
Start it with: virtdev-start ${project}
MESSAGE
fi

if [[ ! -f "${VIRTDEV_SSH_KEY}" ]]; then
  error 6 <<MESSAGE
SSH key not found: '${VIRTDEV_SSH_KEY}'
Place the private key at that path, link it, or set VIRTDEV_SSH_KEY.
MESSAGE
fi

key_permissions="$(stat -c '%a' "${VIRTDEV_SSH_KEY}")"
if [[ "${key_permissions}" != "600" && "${key_permissions}" != "400" ]]; then
  error 7 <<MESSAGE
SSH key permissions too open: '${VIRTDEV_SSH_KEY}' (${key_permissions})
Fix with: chmod 600 '${VIRTDEV_SSH_KEY}'
MESSAGE
fi

exec ssh                             \
  -i "${VIRTDEV_SSH_KEY}"            \
  -p "${port}"                       \
  -o StrictHostKeyChecking=no        \
  -o UserKnownHostsFile=/dev/null    \
  -o LogLevel=ERROR                  \
  dev@127.0.0.1                      \
  "$@"
