#!/usr/bin/env bash
#
# virtdev-transfer <project> <src> <dest>
#
# Copies files between the host and a running project virtual machine
# using rsync over SSH. Prefix the remote path with ':' to indicate
# the virtual machine side.
#
# Upload (host to virtual machine):
#
#     virtdev-transfer myproject local-file :remote-file
#     virtdev-transfer myproject ./src :~/src
#
# Download (virtual machine to host):
#
#     virtdev-transfer myproject :remote-file local-file
#     virtdev-transfer myproject :~/src ./src
#
# Remote paths without a leading '/' are relative to /home/dev.
# Trailing slash semantics follow rsync convention:
# 'dir/' copies contents, 'dir' copies the directory itself.
#
# Requires rsync on both host and guest:
#
#     pacman -S rsync
#
# Configuration via environment variables:
#
#   VIRTDEV_HOME       Default: ${XDG_DATA_HOME:-~/.local/share}/virtdev
#   VIRTDEV_SSH_KEY    Default: ${VIRTDEV_HOME}/ssh/id
#

set -euo pipefail

error() {
  local -r code="${1}"
  cat >&2
  exit "${code}"
}

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"
: "${VIRTDEV_SSH_KEY:="${VIRTDEV_HOME}/ssh/id"}"

if [[ $# -ne 3 ]]; then
  error 1 <<<'usage: virtdev-transfer <project> <src> <dest>'
fi

project="${1}"
src="${2}"
dest="${3}"

if [[ ! "${project}" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  error 2 <<MESSAGE
Invalid project name: '${project}'
Allowed: a-z A-Z 0-9 _ -
MESSAGE
fi

project_directory="${VIRTDEV_HOME}/projects/${project}"

if [[ ! -d "${project_directory}" ]]; then
  error 3 <<<"Project not found: ${project}"
fi

port_file="${project_directory}/port"
if [[ ! -f "${port_file}" ]]; then
  error 4 <<MESSAGE
Project has no port assigned: ${project}
Start the virtual machine first: virtdev-start ${project}
MESSAGE
fi

port="$(< "${port_file}")"

if ! systemctl --user --quiet is-active "virtdev-${project}" 2>/dev/null; then
  error 5 <<MESSAGE
Virtual machine is not running: ${project}
Run it with: virtdev-start ${project}
MESSAGE
fi

if [[ ! -f "${VIRTDEV_SSH_KEY}" ]]; then
  error 6 <<MESSAGE
SSH key not found: '${VIRTDEV_SSH_KEY}'
Place the private key at that path, link it, or set VIRTDEV_SSH_KEY.
MESSAGE
fi

key_permissions="$(stat -c '%a' "${VIRTDEV_SSH_KEY}")"
if [[ "${key_permissions}" != "600" && "${key_permissions}" != "400" ]]; then
  error 7 <<MESSAGE
SSH key permissions too open: ${key_permissions} '${VIRTDEV_SSH_KEY}' 
Fix permissions with: chmod 600 '${VIRTDEV_SSH_KEY}'
MESSAGE
fi

if ! command -v rsync &>/dev/null; then
  error 8 <<MESSAGE
rsync not found
Install it with: pacman -S rsync
MESSAGE
fi

src_is_remote=0
dest_is_remote=0

[[ "${src}" == :* ]] && src_is_remote=1
[[ "${dest}" == :* ]] && dest_is_remote=1

if (( src_is_remote + dest_is_remote == 0 )); then
  error 9 <<MESSAGE
Neither source nor destination is a remote path.
Prefix the remote path with ':' to indicate the virtual machine side.
Example: virtdev-transfer ${project} local-file :remote-file
MESSAGE
fi

if (( src_is_remote + dest_is_remote == 2 )); then
  error 10 <<MESSAGE
Both source and destination are remote paths.
Only one path can be on the virtual machine side.
For virtual machine-local copies: virtdev-ssh ${project} cp src dest
MESSAGE
fi

remote="dev@127.0.0.1"

if (( src_is_remote )); then
  rsync_src="${remote}:${src#:}"
  rsync_dest="${dest}"
  printf 'Copying from %s...\n' "${project}"
else
  rsync_src="${src}"
  rsync_dest="${remote}:${dest#:}"
  printf 'Copying to %s...\n' "${project}"
fi

ssh_command="ssh -i '${VIRTDEV_SSH_KEY}' -p ${port} -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR"

exec rsync -a -e "${ssh_command}" "${rsync_src}" "${rsync_dest}"
