#!/usr/bin/env bash
# lib/virtdev/project
#
# Project enumeration and state queries.
#
# Public functions:
#
#   project_list
#       Prints sorted valid project names, one per line.
#       Excludes the reserved 'maintenance' name and entries
#       that don't match the project name regex. Prints nothing
#       and returns 0 if no projects exist.
#
#   project_is_running <project>
#       Returns 0 if the project's systemd unit is active.
#
#   project_load_running_state <result-array> <project>...
#       Batch-queries systemctl for the running state of the
#       given projects in a single call. Populates the caller's
#       associative array (passed by nameref): keys are project
#       names, values are 1 (running) or 0 (stopped).
#
#   project_is_outdated <project>
#       Returns 0 if the project's generation does not match the
#       sealed base generation. Also returns 0 (outdated) when
#       either generation file is missing. Returns 1 (not outdated)
#       for detached projects.
#
#   project_is_detached <project>
#       Returns 0 if the project's generation file contains the
#       literal string 'detached'.
#
# No reserved exit codes.
#

set -euo pipefail

import validate

: "${VIRTDEV_HOME:="${XDG_DATA_HOME:-${HOME}/.local/share}/virtdev"}"

project_list() {
  local -r projects_dir="${VIRTDEV_HOME}/projects"
  [[ -d "${projects_dir}" ]] || return 0
  local name
  while IFS= read -r name; do
    [[ "${name}" =~ ^[a-zA-Z0-9_-]{1,100}$ ]] || continue
    [[ "${name}" == "maintenance" ]] && continue
    printf '%s\n' "${name}"
  done < <(find "${projects_dir}" -maxdepth 1 -mindepth 1 -type d -printf '%f\n' | sort)
}

project_is_running() {
  systemctl --user --quiet is-active "virtdev-${1}" 2>/dev/null
}

project_load_running_state() {
  local -n _project_result=$1
  shift
  (( $# )) || return 0
  local -a names=("$@")
  local -a units=()
  local project
  for project in "${names[@]}"; do
    units+=("virtdev-${project}")
  done
  local -a statuses=()
  mapfile -t statuses < <(systemctl --user is-active "${units[@]}" 2>/dev/null || true)
  local i
  for (( i = 0; i < ${#names[@]}; i++ )); do
    if [[ "${statuses[i]:-}" == "active" ]]; then
      _project_result["${names[i]}"]=1
    else
      _project_result["${names[i]}"]=0
    fi
  done
}

project_is_outdated() {
  local project="${1}"
  project_is_detached "${project}" && return 1
  local -r base_file="${VIRTDEV_HOME}/system/generation"
  local -r project_file="${VIRTDEV_HOME}/projects/${project}/generation"
  if [[ ! -f "${base_file}" || ! -f "${project_file}" ]]; then
    return 0
  fi
  local base_gen project_gen
  base_gen="$(< "${base_file}")"
  project_gen="$(< "${project_file}")"
  [[ "${project_gen}" != "${base_gen}" ]]
}

project_is_detached() {
  local project="${1}"
  local -r generation_file="${VIRTDEV_HOME}/projects/${project}/generation"
  [[ -f "${generation_file}" ]] && [[ "$(< "${generation_file}")" == "detached" ]]
}
