#!/usr/bin/env bash
#
# import — bootstrap module for the virtdev library system.
#
# Source this file from any bin/virtdev-* script to get the library
# infrastructure. Replaces the ~10-line bootstrap block that every
# consumer used to duplicate inline.
#
# Consumer usage (2 lines, right after set -euo pipefail):
#
#     # shellcheck disable=SC1090
#     source "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../lib/virtdev/import"
#
#     import error validate lock   # whatever the script needs
#
# Exports into the sourcing shell's scope:
#
#   virtdev_library_directory   lib/virtdev/ resolved path (used by import)
#   virtdev_bin_directory       bin/ resolved path (for subprocess invocation)
#   virtdev_loaded_libraries    associative array tracking loaded libraries
#   import()                    source libraries by name, idempotent
#
# The ../lib/virtdev path in the consumer's source line resolves
# correctly for both the dev tree (bin → lib/virtdev) and the
# pacman-installed package (/usr/bin → /usr/lib/virtdev).
#

set -euo pipefail

virtdev_library_directory="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
# shellcheck disable=SC2034  # used by consumers (virtdev-recreate, virtdev-upgrade)
virtdev_bin_directory="${virtdev_library_directory}/../../bin"

declare -A virtdev_loaded_libraries=([import]=1)

import() {
  local f
  for f in "$@"; do
    [[ -v virtdev_loaded_libraries[$f] ]] && continue
    virtdev_loaded_libraries[$f]=1
    # shellcheck disable=SC1090
    source -p "${virtdev_library_directory}" "${f}"
  done
}
