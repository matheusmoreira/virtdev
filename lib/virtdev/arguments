#!/usr/bin/env bash
#
# arguments library: declarative flag parser and usage generator.
# Public:
#   arguments_parse <spec_name> <flags_name> <positional_name> "$@"
#   arguments_usage <spec_name>
# Exit codes:
#   64  usage error (unknown flag, missing value, missing required,
#       bool with value, invalid spec type tag)
#
# Spec format (assoc array, key = flag name without leading --):
#   bool      Flag takes no value; presence sets to 1, absence to 0.
#   value     Flag takes one value; absence leaves "".
#   required  Same as value, plus post-parse error if not given.
#
# Result format:
#   flags        assoc array, populated with parsed values
#   positional   indexed array, every non-flag arg + everything after
#                a -- terminator
#
# Flags and positionals may be interleaved (GNU-style). Use -- to
# force all remaining arguments into positional regardless of prefix.
#
# The library prepends -- when matching against argv. Spec keys keep
# hyphens verbatim. Caller may pre-set flags[<key>] before calling to
# override the default; pre-set required keys are exempt from the
# missing-value check.
#
# --flag=value form is supported for value/required types. -- is the
# end-of-flags terminator. Unknown long flags error 64.
#
# Short aliases: single-dash single-character flags (-v, -y, -p val)
# are supported when a <spec_name>_short companion array exists.
# Keys are single characters, values are the long flag names they
# alias. Without the companion, all -* args error 64.
#
# Clustered short flags: -vy expands to -v -y. All characters except
# the last must be bool. The last may be value/required, consuming the
# next arg. Requires the _short companion array.
#
# Usage generation:
#   arguments_usage derives a usage line from the spec and optional
#   companion arrays discovered by naming convention:
#     <spec_name>_short          assoc  short-to-long flag aliases
#     <spec_name>_placeholders   assoc  placeholder text for value/required
#     <spec_name>_positionals    indexed  positional args (suffix encoding)
#   Positional suffixes: (none)=required, ?=optional, +=variadic 1+,
#   *=variadic 0+. Script name auto-detected via basename "$0".
#
set -euo pipefail
import error

readonly arguments_usage_exit_code=64

arguments_parse() {
  local -n _arguments_spec="${1}"
  local -n _arguments_flags="${2}"
  local -n _arguments_positional="${3}"

  local _arguments_short_name="${1}_short"
  local _arguments_has_short=0
  if declare -p "${_arguments_short_name}" &>/dev/null; then
    # shellcheck disable=SC2178  # nameref, not scalar reassignment
    local -n _arguments_short="${_arguments_short_name}"
    _arguments_has_short=1
  fi

  shift 3

  local key type short_key short_target
  for key in "${!_arguments_spec[@]}"; do
    type="${_arguments_spec[$key]}"
    case "${type}" in
      bool|value|required) ;;
      *)
        error "${arguments_usage_exit_code}" \
          <<<"invalid argument type for --${key}: ${type}"
        ;;
    esac
  done

  if (( _arguments_has_short )); then
    for short_key in "${!_arguments_short[@]}"; do
      if [[ "${#short_key}" -ne 1 ]]; then
        error "${arguments_usage_exit_code}" \
          <<<"invalid short flag key: '${short_key}' (must be a single character)"
      fi
      short_target="${_arguments_short[$short_key]}"
      if [[ ! -v _arguments_spec[$short_target] ]]; then
        error "${arguments_usage_exit_code}" \
          <<<"short flag -${short_key} aliases unknown flag: --${short_target}"
      fi
    done
  fi

  for key in "${!_arguments_spec[@]}"; do
    [[ -v _arguments_flags[$key] ]] && continue
    case "${_arguments_spec[$key]}" in
      bool)  _arguments_flags["${key}"]=0 ;;
      value) _arguments_flags["${key}"]="" ;;
      required) ;;
    esac
  done

  local arg flag_name flag_value short_char
  while (( $# > 0 )); do
    arg="${1}"
    case "${arg}" in
      --)
        shift
        _arguments_positional+=("$@")
        return 0
        ;;
      --*=*)
        flag_name="${arg%%=*}"
        flag_name="${flag_name#--}"
        flag_value="${arg#*=}"
        if [[ ! -v _arguments_spec[$flag_name] ]]; then
          error "${arguments_usage_exit_code}" \
            <<<"unknown flag: --${flag_name}"
        fi
        if [[ "${_arguments_spec[$flag_name]}" == "bool" ]]; then
          error "${arguments_usage_exit_code}" \
            <<<"--${flag_name} does not take a value"
        fi
        _arguments_flags["${flag_name}"]="${flag_value}"
        shift
        ;;
      --*)
        flag_name="${arg#--}"
        if [[ ! -v _arguments_spec[$flag_name] ]]; then
          error "${arguments_usage_exit_code}" \
            <<<"unknown flag: --${flag_name}"
        fi
        case "${_arguments_spec[$flag_name]}" in
          bool)
            _arguments_flags["${flag_name}"]=1
            shift
            ;;
          value|required)
            if (( $# < 2 )) || [[ "${2}" == "--" ]]; then
              error "${arguments_usage_exit_code}" \
                <<<"--${flag_name} requires a value"
            fi
            _arguments_flags["${flag_name}"]="${2}"
            shift 2
            ;;
        esac
        ;;
      -?)
        short_char="${arg#-}"
        if (( _arguments_has_short )) \
           && [[ -v _arguments_short[$short_char] ]]; then
          flag_name="${_arguments_short[$short_char]}"
        else
          error "${arguments_usage_exit_code}" \
            <<<"unknown flag: ${arg}"
        fi
        case "${_arguments_spec[$flag_name]}" in
          bool)
            _arguments_flags["${flag_name}"]=1
            shift
            ;;
          value|required)
            if (( $# < 2 )) || [[ "${2}" == "--" ]]; then
              error "${arguments_usage_exit_code}" \
                <<<"-${short_char} (--${flag_name}) requires a value"
            fi
            _arguments_flags["${flag_name}"]="${2}"
            shift 2
            ;;
        esac
        ;;
      -*)
        if (( ! _arguments_has_short )); then
          error "${arguments_usage_exit_code}" \
            <<<"unknown flag: ${arg}"
        fi
        # Expand the cluster character by character. Intermediate
        # characters must be bool (no value to consume); only the last
        # character may be value/required (consuming the next argv
        # element). The shift that retires the cluster arg from argv
        # happens inside the last-character case, not after the loop,
        # because value/required needs shift 2 (cluster + value arg)
        # while bool needs shift 1 (cluster only).
        local _arguments_cluster="${arg#-}"
        local _arguments_ci _arguments_cc
        for (( _arguments_ci=0; _arguments_ci < ${#_arguments_cluster}; _arguments_ci++ )); do
          _arguments_cc="${_arguments_cluster:_arguments_ci:1}"
          if [[ ! -v _arguments_short[$_arguments_cc] ]]; then
            error "${arguments_usage_exit_code}" \
              <<<"unknown flag: -${_arguments_cc} (in ${arg})"
          fi
          flag_name="${_arguments_short[$_arguments_cc]}"
          if (( _arguments_ci < ${#_arguments_cluster} - 1 )); then
            if [[ "${_arguments_spec[$flag_name]}" != "bool" ]]; then
              error "${arguments_usage_exit_code}" \
                <<<"-${_arguments_cc} (--${flag_name}) requires a value and cannot be clustered"
            fi
            _arguments_flags["${flag_name}"]=1
          else
            case "${_arguments_spec[$flag_name]}" in
              bool)
                _arguments_flags["${flag_name}"]=1
                shift
                ;;
              value|required)
                if (( $# < 2 )) || [[ "${2}" == "--" ]]; then
                  error "${arguments_usage_exit_code}" \
                    <<<"-${_arguments_cc} (--${flag_name}) requires a value"
                fi
                _arguments_flags["${flag_name}"]="${2}"
                shift 2
                ;;
            esac
          fi
        done
        ;;
      *)
        _arguments_positional+=("${arg}")
        shift
        ;;
    esac
  done

  local -a missing=()
  for key in "${!_arguments_spec[@]}"; do
    if [[ "${_arguments_spec[$key]}" == "required" ]] \
       && [[ ! -v _arguments_flags[$key] ]]; then
      missing+=("--${key}")
    fi
  done
  if (( ${#missing[@]} > 0 )); then
    error "${arguments_usage_exit_code}" \
      <<<"missing required flag(s): ${missing[*]}"
  fi
}

arguments_usage() {
  local -n _au_spec="${1}"
  local _au_short_name="${1}_short"
  local _au_ph_name="${1}_placeholders"
  local _au_pos_name="${1}_positionals"
  local _au_has_short=0
  local _au_has_ph=0
  local _au_has_pos=0

  if declare -p "${_au_short_name}" &>/dev/null; then
    # shellcheck disable=SC2178  # nameref, not scalar reassignment
    local -n _au_short="${_au_short_name}"
    _au_has_short=1
  fi

  if declare -p "${_au_ph_name}" &>/dev/null; then
    # shellcheck disable=SC2178  # nameref, not scalar reassignment
    local -n _au_ph="${_au_ph_name}"
    _au_has_ph=1
  fi

  if declare -p "${_au_pos_name}" &>/dev/null; then
    # shellcheck disable=SC2178  # nameref, not scalar reassignment
    local -n _au_pos="${_au_pos_name}"
    _au_has_pos=1
  fi

  local -A _au_long_to_short=()
  if (( _au_has_short )); then
    local _au_s
    for _au_s in "${!_au_short[@]}"; do
      _au_long_to_short["${_au_short[$_au_s]}"]="${_au_s}"
    done
  fi

  local -a _au_required=() _au_value=() _au_bool=()
  local _au_key _au_type
  for _au_key in "${!_au_spec[@]}"; do
    _au_type="${_au_spec[$_au_key]}"
    case "${_au_type}" in
      required) _au_required+=("${_au_key}") ;;
      value)    _au_value+=("${_au_key}") ;;
      bool)     _au_bool+=("${_au_key}") ;;
    esac
  done

  if (( ${#_au_required[@]} > 0 )); then
    readarray -t _au_required < <(printf '%s\n' "${_au_required[@]}" | sort)
  fi
  if (( ${#_au_value[@]} > 0 )); then
    readarray -t _au_value < <(printf '%s\n' "${_au_value[@]}" | sort)
  fi
  if (( ${#_au_bool[@]} > 0 )); then
    readarray -t _au_bool < <(printf '%s\n' "${_au_bool[@]}" | sort)
  fi

  local _au_out
  _au_out="usage: $(basename "$0")"
  local _au_placeholder _au_flag_label _au_type

  for _au_key in "${_au_required[@]}" "${_au_value[@]}" "${_au_bool[@]}"; do
    _au_flag_label="--${_au_key}"
    if [[ -v _au_long_to_short[$_au_key] ]]; then
      _au_flag_label="-${_au_long_to_short[$_au_key]}|${_au_flag_label}"
    fi
    _au_type="${_au_spec[$_au_key]}"
    if [[ "${_au_type}" == bool ]]; then
      _au_out+=" [${_au_flag_label}]"
    else
      _au_placeholder="value"
      (( _au_has_ph )) && [[ -v _au_ph[$_au_key] ]] \
        && _au_placeholder="${_au_ph[$_au_key]}"
      if [[ "${_au_type}" == required ]]; then
        _au_out+=" ${_au_flag_label} <${_au_placeholder}>"
      else
        _au_out+=" [${_au_flag_label} <${_au_placeholder}>]"
      fi
    fi
  done

  if (( _au_has_pos )); then
    local _au_entry _au_mod _au_name
    for _au_entry in "${_au_pos[@]}"; do
      _au_mod="${_au_entry: -1}"
      case "${_au_mod}" in
        '?') _au_name="${_au_entry%?}" ; _au_out+=" [${_au_name}]" ;;
        '+') _au_name="${_au_entry%?}" ; _au_out+=" <${_au_name}...>" ;;
        '*') _au_name="${_au_entry%?}" ; _au_out+=" [${_au_name}...]" ;;
        *)   _au_out+=" <${_au_entry}>" ;;
      esac
    done
  fi

  printf '%s\n' "${_au_out}"
}
